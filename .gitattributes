# Shell scripts must use LF line endings (deployed to Linux/OpenWRT,
# and bun's built-in shell on Windows can't tolerate CRLF in scripts).
*.sh text eol=lf
scripts/**/*.sh text eol=lf
scripts/etc/init.d/* text eol=lf
scripts/etc/qmanager/* text eol=lf
scripts/etc/systemd/system/* text eol=lf
scripts/etc/sudoers.d/* text eol=lf
scripts/etc/udev/rules.d/* text eol=lf
scripts/usr/bin/* text eol=lf
scripts/usr/bin/bridge_traffic_monitor_rm551 binary
qmanager-installer.sh text eol=lf
build.sh text eol=lf
