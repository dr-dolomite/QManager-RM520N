#!/bin/sh
# =============================================================================
# qmanager_profile_apply — Detached Profile Application Script
# =============================================================================
# Spawned as a detached process by apply.sh CGI. Applies a saved profile's
# settings to the modem and system, one step at a time, with progress
# tracking via a JSON state file.
#
# Usage:
#   qmanager_profile_apply <profile_id>
#
# State file: /tmp/qmanager_profile_state.json
# PID file:   /tmp/qmanager_profile_apply.pid
#
# Apply steps (4 total):
#   1. APN      — AT+CGDCONT (no modem reboot)
#   2. TTL/HL   — iptables/ip6tables (no modem lock needed)
#   3. Scenario — AT+QNWPREFCFG mode_pref + optional band locks (skipped if
#                 no scenario_id bound to the profile)
#   4. IMEI     — AT+EGMR + AT+CFUN=1,1 reboot (most disruptive, last)
#
# Step order rationale: scenario MUST come before IMEI because AT+CFUN=1,1
# reboots the modem and would discard any radio config applied after it.
#
# Architecture: CUSTOM_SIM_PROFILE_ARCHITECTURE_v2.md §5.2, §7
# Dependencies: qcmd, qlog.sh, profile_mgr.sh
# Install location: /usr/bin/qmanager_profile_apply
# =============================================================================

# --- Logging -----------------------------------------------------------------
. /usr/lib/qmanager/qlog.sh 2>/dev/null || {
    qlog_init() { :; }
    qlog_debug() { :; }
    qlog_info() { :; }
    qlog_warn() { :; }
    qlog_error() { :; }
}
qlog_init "profile_apply"
[ -f /usr/lib/qmanager/cgi_at.sh ] && . /usr/lib/qmanager/cgi_at.sh

# --- Events (for append_event) -----------------------------------------------
# Must define EVENTS_FILE and MAX_EVENTS before sourcing events.sh
EVENTS_FILE="/tmp/qmanager_events.json"
MAX_EVENTS=50
. /usr/lib/qmanager/events.sh 2>/dev/null || {
    append_event() { :; }
}

# --- Source profile manager library ------------------------------------------
[ -f /usr/lib/qmanager/profile_mgr.sh ]   && . /usr/lib/qmanager/profile_mgr.sh
[ -f /usr/lib/qmanager/platform.sh ]      && . /usr/lib/qmanager/platform.sh
[ -f /usr/lib/qmanager/ttl_state.sh ]     && . /usr/lib/qmanager/ttl_state.sh
[ -f /usr/lib/qmanager/scenario_mgr.sh ]  && . /usr/lib/qmanager/scenario_mgr.sh

# --- Configuration -----------------------------------------------------------
STATE_FILE="/tmp/qmanager_profile_state.json"
# Pending re-apply marker: auto_apply_profile writes this when it finds THIS
# worker holding the PID lock; we consume it on exit (after the lock is freed).
PROFILE_PENDING_APPLY_FILE="/tmp/qmanager_profile_pending_apply"

# Sip-don't-gulp gap between AT commands (seconds)
CMD_GAP=0.3
# Max seconds to wait for modem to come back after AT+CFUN=1,1
REBOOT_TIMEOUT=60

# --- Validate arguments ------------------------------------------------------
PROFILE_ID="$1"

if [ -z "$PROFILE_ID" ]; then
    qlog_error "No profile ID provided"
    exit 1
fi

# Auto mode: set only when spawned by auto_apply_profile (SIM-driven). Enables
# the stale-SIM guard below. Manual Activate (apply.sh) omits it and keeps its
# exact prior semantics — no guard, never aborts on a SIM read.
AUTO_MODE=""
if [ "$2" = "--auto" ]; then
    AUTO_MODE=1
fi

# --- Auto-mode stale-SIM guard helpers ---------------------------------------
# _auto_read_live_iccid — canonical QCCID parse + iccid_canonicalize, 3x1s
# retry. Prints the canonicalized ICCID (empty if every read failed). Empty is
# a "don't know" signal — callers must NOT abort on it (best-effort guard).
_auto_read_live_iccid() {
    local _ali_raw
    local _ali_i
    _ali_i=1
    while [ "$_ali_i" -le 3 ]; do
        _ali_raw=$(qcmd 'AT+QCCID' 2>/dev/null | grep '+QCCID:' | sed 's/+QCCID: //g' | tr -d '\r ')
        if [ -n "$_ali_raw" ]; then
            iccid_canonicalize "$_ali_raw"
            return 0
        fi
        sleep 1
        _ali_i=$((_ali_i + 1))
    done
    printf ''
    return 0
}

# _auto_sim_guard <phase> — returns 0 (proceed) unless, in auto mode, the profile
# is SIM-bound AND the live ICCID now differs from the profile's sim_iccid — i.e.
# a newer SIM switch has superseded this apply. An empty live read never aborts.
_auto_sim_guard() {
    local _asg_phase
    local _asg_live
    local _asg_want
    _asg_phase="$1"
    [ -z "$AUTO_MODE" ] && return 0
    [ -z "$p_sim_iccid" ] && return 0
    _asg_live=$(_auto_read_live_iccid)
    [ -z "$_asg_live" ] && return 0
    _asg_want=$(iccid_canonicalize "$p_sim_iccid")
    [ "$_asg_live" = "$_asg_want" ] && return 0
    qlog_warn "[auto] SIM changed under apply ($_asg_phase): live=$_asg_live != profile=$_asg_want — superseding"
    return 1
}

# _consume_pending_apply — called from the EXIT trap STRICTLY AFTER the PID lock
# is freed, so a re-spawned auto_apply_profile can acquire the lock instead of
# busy-skipping again. If a pending marker exists, consume it and re-run
# auto_apply for the FRESHEST live SIM (read now, not the stored value) so the
# newest state wins; fall back to the stored ICCID only if the live read is
# empty. Terminates: a re-run that again finds the lock busy just rewrites the
# pending file for the next worker's exit — no loop.
_consume_pending_apply() {
    [ -f "$PROFILE_PENDING_APPLY_FILE" ] || return 0
    local _cp_stored
    local _cp_live
    local _cp_i
    local _cp_iccid
    _cp_stored=$(head -1 "$PROFILE_PENDING_APPLY_FILE" 2>/dev/null | cut -f1)
    rm -f "$PROFILE_PENDING_APPLY_FILE"
    _cp_live=""
    _cp_i=1
    while [ "$_cp_i" -le 3 ]; do
        _cp_live=$(qcmd 'AT+QCCID' 2>/dev/null | grep '+QCCID:' | sed 's/+QCCID: //g' | tr -d '\r ')
        [ -n "$_cp_live" ] && break
        sleep 1
        _cp_i=$((_cp_i + 1))
    done
    _cp_iccid="$_cp_live"
    [ -z "$_cp_iccid" ] && _cp_iccid="$_cp_stored"
    [ -z "$_cp_iccid" ] && return 0
    qlog_info "[requeue] Consuming pending apply; re-running auto_apply for ICCID ...$(printf '%s' "$_cp_iccid" | tail -c 4)"
    ( . /usr/lib/qmanager/profile_mgr.sh && auto_apply_profile "$_cp_iccid" "requeue" ) </dev/null >/dev/null 2>&1 &
}

# --- Singleton enforcement via PID file --------------------------------------
if ! profile_acquire_lock; then
    qlog_warn "Apply already running (PID: $_profile_lock_pid)"
    exit 1
fi

# --- Cleanup trap: remove PID file, THEN consume any queued re-apply ----------
# Order is critical: the pending re-apply must run only after the PID lock is
# gone, or the re-spawned auto_apply would busy-skip and drop the marker.
cleanup() {
    rm -f "$PROFILE_APPLY_PID_FILE"
    _consume_pending_apply
}
trap cleanup EXIT INT TERM

# =============================================================================
# State File Management
# =============================================================================

# Step names (4 steps: scenario inserted between ttl_hl and imei)
STEP_NAMES="apn ttl_hl scenario imei"
STEP_COUNT=4

# Step statuses (initialized to "pending")
step_status_apn="pending"
step_status_ttl_hl="pending"
step_status_scenario="pending"
step_status_imei="pending"

# Step details
step_detail_apn=""
step_detail_ttl_hl=""
step_detail_scenario=""
step_detail_imei=""

# Global state
apply_status="applying"
apply_current_step=0
apply_requires_reboot="false"
apply_error="null"
apply_started_at=$(date +%s)
apply_profile_name=""

# Counters for final status
steps_done=0
steps_failed=0
steps_skipped=0

# --- Write the state file (atomic mv) ----------------------------------------
write_state() {
    local tmp="${STATE_FILE}.tmp"
    local err_val
    if [ "$apply_error" = "null" ]; then
        err_val="null"
    else
        err_val="$apply_error"
    fi

    jq -n \
        --arg status       "$apply_status" \
        --arg profile_id   "$PROFILE_ID" \
        --arg profile_name "$apply_profile_name" \
        --argjson started  "$apply_started_at" \
        --argjson cur_step "$apply_current_step" \
        --argjson total    "$STEP_COUNT" \
        --arg s1_status    "$step_status_apn" \
        --arg s1_detail    "$step_detail_apn" \
        --arg s2_status    "$step_status_ttl_hl" \
        --arg s2_detail    "$step_detail_ttl_hl" \
        --arg s3_status    "$step_status_scenario" \
        --arg s3_detail    "$step_detail_scenario" \
        --arg s4_status    "$step_status_imei" \
        --arg s4_detail    "$step_detail_imei" \
        --argjson reboot   "$apply_requires_reboot" \
        --arg err          "$err_val" \
        '{
            status: $status,
            profile_id: $profile_id,
            profile_name: $profile_name,
            started_at: $started,
            current_step: $cur_step,
            total_steps: $total,
            steps: [
                {name: "apn",      status: $s1_status, detail: $s1_detail},
                {name: "ttl_hl",   status: $s2_status, detail: $s2_detail},
                {name: "scenario", status: $s3_status, detail: $s3_detail},
                {name: "imei",     status: $s4_status, detail: $s4_detail}
            ],
            requires_reboot: $reboot,
            error: (if $err == "null" then null else $err end)
        }' > "$tmp"
    mv "$tmp" "$STATE_FILE"
}

# --- Step lifecycle helpers ---------------------------------------------------
mark_step_running() {
    local step="$1"
    local detail="$2"
    # Only increment current_step on first transition (pending → running),
    # not on subsequent detail updates while already running.
    local prev_status
    eval "prev_status=\"\$step_status_${step}\""
    eval "step_status_${step}=\"running\""
    eval "step_detail_${step}=\"\$detail\""
    if [ "$prev_status" != "running" ]; then
        apply_current_step=$((apply_current_step + 1))
    fi
    write_state
}

mark_step_done() {
    local step="$1"
    local detail="$2"
    eval "step_status_${step}=\"done\""
    eval "step_detail_${step}=\"\$detail\""
    steps_done=$((steps_done + 1))
    write_state
}

mark_step_failed() {
    local step="$1"
    local detail="$2"
    eval "step_status_${step}=\"failed\""
    eval "step_detail_${step}=\"\$detail\""
    steps_failed=$((steps_failed + 1))
    write_state
}

mark_step_skipped() {
    local step="$1"
    local detail="$2"
    eval "step_status_${step}=\"skipped\""
    eval "step_detail_${step}=\"\$detail\""
    steps_skipped=$((steps_skipped + 1))
    # Don't increment apply_current_step here — mark_step_running already
    # incremented it when the step first transitioned to "running".
    write_state
}

# =============================================================================
# Load Profile
# =============================================================================
qlog_info "Starting profile apply: $PROFILE_ID"

profile_json=$(profile_get "$PROFILE_ID")
if [ -z "$profile_json" ]; then
    qlog_error "Profile not found: $PROFILE_ID"
    apply_status="failed"
    apply_error="Profile not found"
    write_state
    exit 1
fi

# Extract settings from the profile JSON using jq with proper nested paths
p_name=$(printf '%s' "$profile_json" | jq -r '.name // empty')
apply_profile_name="$p_name"

p_apn_name=$(printf '%s' "$profile_json" | jq -r '.settings.apn.name // empty')
p_apn_cid=$(printf '%s' "$profile_json" | jq -r '.settings.apn.cid // empty | tostring')
p_pdp_type=$(printf '%s' "$profile_json" | jq -r '.settings.apn.pdp_type // empty')
p_imei=$(printf '%s' "$profile_json" | jq -r '.settings.imei // empty')
p_ttl=$(printf '%s' "$profile_json" | jq -r '.settings.ttl // empty | tostring')
p_hl=$(printf '%s' "$profile_json" | jq -r '.settings.hl // empty | tostring')
p_scenario_id=$(printf '%s' "$profile_json" | jq -r '.settings.scenario_id // empty')
p_sim_iccid=$(printf '%s' "$profile_json" | jq -r '.sim_iccid // empty')

# Defaults
[ -z "$p_apn_cid" ] && p_apn_cid=1
[ -z "$p_ttl" ] && p_ttl=0
[ -z "$p_hl" ] && p_hl=0

qlog_info "Applying profile: $p_name (APN=$p_apn_name, CID=$p_apn_cid)"

# Write initial state
write_state

# --- Auto-mode at-start stale-SIM guard --------------------------------------
# If the SIM already changed before we ran the first step, this apply was
# superseded by a newer switch. Abort cleanly WITHOUT touching the active marker
# (the authoritative apply for the current SIM owns it). The EXIT trap still runs
# the pending re-apply. "failed" is a terminal state for the status poller.
if ! _auto_sim_guard "pre-apply"; then
    apply_status="failed"
    apply_error="superseded_sim_changed"
    write_state
    append_event "profile_failed" "Profile '$p_name' apply superseded — active SIM changed before apply" "warning"
    exit 0
fi

# =============================================================================
# Step 1: APN
# =============================================================================
apply_apn() {
    mark_step_running "apn" "Checking APN configuration..."

    # Read current APN for this CID
    local cgdcont_resp
    cgdcont_resp=$(run_at "AT+CGDCONT?")
    if [ $? -ne 0 ]; then
        mark_step_failed "apn" "Failed to read current APN"
        return
    fi

    # Parse current APN for the target CID
    # Response format: +CGDCONT: <cid>,"<pdp_type>","<apn>",...
    # Using awk -F'"' — $2=pdp_type, $4=apn (same approach as current_settings.sh)
    local current_apn
    current_apn=$(printf '%s' "$cgdcont_resp" | grep "+CGDCONT: ${p_apn_cid}," | awk -F'"' '{print $4}' | head -1)

    # Skip if APN hasn't changed
    if [ "$current_apn" = "$p_apn_name" ]; then
        mark_step_skipped "apn" "APN already set to ${p_apn_name} (CID ${p_apn_cid})"
        return
    fi

    # Set APN
    local pdp="${p_pdp_type:-IPV4V6}"
    local at_cmd="AT+CGDCONT=${p_apn_cid},\"${pdp}\",\"${p_apn_name}\""
    mark_step_running "apn" "Setting APN to ${p_apn_name} (CID ${p_apn_cid})..."

    local resp
    resp=$(run_at "$at_cmd")
    if [ $? -ne 0 ]; then
        mark_step_failed "apn" "Failed to set APN"
        return
    fi

    sleep "$CMD_GAP"

    mark_step_done "apn" "Set APN to ${p_apn_name} (CID ${p_apn_cid})"
}

# =============================================================================
# Step 2: TTL / HL (system-level, no modem lock needed)
# =============================================================================
apply_ttl_hl() {
    mark_step_running "ttl_hl" "Checking TTL/HL settings..."

    # Read live kernel state for comparison
    local current_ttl current_hl
    set -- $(ttl_state_read_live)
    current_ttl="${1:-0}"
    current_hl="${2:-0}"

    local new_ttl="${p_ttl:-0}"
    local new_hl="${p_hl:-0}"

    if [ "$current_ttl" = "$new_ttl" ] && [ "$current_hl" = "$new_hl" ]; then
        mark_step_skipped "ttl_hl" "TTL/HL unchanged (TTL=$new_ttl, HL=$new_hl)"
        return
    fi

    mark_step_running "ttl_hl" "Applying TTL=$new_ttl, HL=$new_hl..."

    if ttl_state_apply "$new_ttl" "$new_hl" && ttl_state_write_persisted "$new_ttl" "$new_hl"; then
        mark_step_done "ttl_hl" "Applied TTL=$new_ttl, HL=$new_hl"
    else
        mark_step_failed "ttl_hl" "Failed to apply or persist TTL=$new_ttl, HL=$new_hl"
    fi
}

# =============================================================================
# Step 3: Scenario (radio mode + optional band locks)
# =============================================================================
apply_scenario() {
    mark_step_running "scenario" "Checking scenario binding..."

    # No scenario bound — skip cleanly
    if [ -z "$p_scenario_id" ]; then
        mark_step_skipped "scenario" "No scenario bound"
        return
    fi

    case "$p_scenario_id" in
        balanced|gaming|streaming)
            # Built-in scenario — scenario_apply resolves mode internally
            mark_step_running "scenario" "Applying scenario: $p_scenario_id..."
            if scenario_apply "$p_scenario_id"; then
                if [ -n "$_scenario_apply_failed" ]; then
                    # mode_pref succeeded but band lock(s) failed (partial)
                    scenario_set_active "$p_scenario_id"
                    mark_step_failed "scenario" "Partial: band lock failed for: $_scenario_apply_failed"
                else
                    scenario_set_active "$p_scenario_id"
                    mark_step_done "scenario" "Scenario $p_scenario_id applied"
                fi
            else
                mark_step_failed "scenario" "Failed to apply scenario $p_scenario_id (mode_pref AT error)"
            fi
            ;;
        custom-*)
            # Custom scenario — must look up config from disk
            mark_step_running "scenario" "Looking up custom scenario: $p_scenario_id..."
            local sc_json
            sc_json=$(scenario_lookup_custom "$p_scenario_id")
            if [ $? -ne 0 ] || [ -z "$sc_json" ]; then
                mark_step_skipped "scenario" "Scenario $p_scenario_id no longer exists"
                return
            fi

            # Parse mode and bands from the stored scenario JSON
            local sc_mode sc_lte sc_nsa sc_sa
            sc_mode=$(printf '%s' "$sc_json" | jq -r '.config.atModeValue // empty')
            sc_lte=$(printf '%s' "$sc_json"  | jq -r '.config.lte_bands // empty')
            sc_nsa=$(printf '%s' "$sc_json"  | jq -r '.config.nsa_nr_bands // empty')
            sc_sa=$(printf '%s' "$sc_json"   | jq -r '.config.sa_nr_bands // empty')

            if [ -z "$sc_mode" ]; then
                mark_step_failed "scenario" "Custom scenario $p_scenario_id has no mode configured"
                return
            fi

            mark_step_running "scenario" "Applying custom scenario: $p_scenario_id (mode=$sc_mode)..."
            if scenario_apply "$p_scenario_id" "$sc_mode" "$sc_lte" "$sc_nsa" "$sc_sa"; then
                if [ -n "$_scenario_apply_failed" ]; then
                    scenario_set_active "$p_scenario_id"
                    mark_step_failed "scenario" "Partial: band lock failed for: $_scenario_apply_failed"
                else
                    scenario_set_active "$p_scenario_id"
                    mark_step_done "scenario" "Custom scenario $p_scenario_id applied"
                fi
            else
                mark_step_failed "scenario" "Failed to apply custom scenario $p_scenario_id (mode_pref AT error)"
            fi
            ;;
        *)
            # scenario_id value is unrecognized — treat as a soft skip so
            # IMEI still runs. This guards against stale data from old profiles.
            mark_step_skipped "scenario" "Unrecognized scenario_id: $p_scenario_id"
            ;;
    esac
}

# =============================================================================
# Step 4: IMEI (most disruptive — last)
# =============================================================================
apply_imei() {
    mark_step_running "imei" "Checking IMEI..."

    # Skip if no IMEI specified in profile
    if [ -z "$p_imei" ]; then
        mark_step_skipped "imei" "No IMEI specified in profile"
        return
    fi

    # Read current IMEI
    local current_imei
    current_imei=$(run_at "AT+CGSN")
    if [ $? -ne 0 ]; then
        mark_step_failed "imei" "Failed to read current IMEI"
        return
    fi
    # Clean up the response (just the 15-digit IMEI)
    current_imei=$(printf '%s' "$current_imei" | grep -o '[0-9]\{15\}' | head -1)

    if [ "$current_imei" = "$p_imei" ]; then
        mark_step_skipped "imei" "IMEI already set to $p_imei"
        return
    fi

    mark_step_running "imei" "Writing IMEI ${p_imei}..."

    # Write new IMEI to modem NVM
    local resp
    resp=$(run_at "AT+EGMR=1,7,\"${p_imei}\"")
    if [ $? -ne 0 ]; then
        mark_step_failed "imei" "Failed to write IMEI"
        return
    fi

    sleep "$CMD_GAP"

    # Pre-set active profile before modem reboot — AT+CFUN=1,1 may trigger
    # a full system reboot on some configurations (USB bus reset), which would
    # kill this script before finalization. APN + TTL already applied above.
    set_active_profile "$PROFILE_ID"

    # Trigger modem reboot to apply IMEI
    apply_requires_reboot="true"
    mark_step_running "imei" "Rebooting modem to apply new IMEI..."
    write_state

    run_at "AT+CFUN=1,1" 2>/dev/null
    # After CFUN=1,1 the modem goes offline — serial commands will fail

    # Wait for modem to come back
    local waited=0
    local modem_back=0
    while [ "$waited" -lt "$REBOOT_TIMEOUT" ]; do
        sleep 2
        waited=$((waited + 2))
        local check
        check=$(qcmd "AT" 2>/dev/null)
        case "$check" in
            *OK*)
                modem_back=1
                break
                ;;
        esac
    done

    if [ "$modem_back" -eq 0 ]; then
        mark_step_failed "imei" "Modem did not respond after reboot (waited ${REBOOT_TIMEOUT}s)"
        return
    fi

    sleep 1

    # Verify new IMEI
    local verify_imei
    verify_imei=$(run_at "AT+CGSN")
    verify_imei=$(printf '%s' "$verify_imei" | grep -o '[0-9]\{15\}' | head -1)

    if [ "$verify_imei" = "$p_imei" ]; then
        mark_step_done "imei" "IMEI changed to $p_imei (modem rebooted)"
    else
        mark_step_failed "imei" "IMEI verify failed: expected $p_imei, got $verify_imei"
    fi
}

# =============================================================================
# EXECUTE ALL STEPS (ordered by impact: least disruptive first)
# =============================================================================
apply_apn
sleep "$CMD_GAP"

apply_ttl_hl
# No CMD_GAP — TTL doesn't use modem

apply_scenario
sleep "$CMD_GAP"

apply_imei

# =============================================================================
# FINALIZE
# =============================================================================

# --- Auto-mode pre-finalize stale-SIM guard ----------------------------------
# A rapid back-to-back switch can supersede this apply while it ran; committing
# the active marker now would pin the WRONG SIM's profile. Re-verify the live
# SIM still matches; on mismatch finalize as "failed" and do NOT write the
# marker. The EXIT trap's pending re-apply then reconciles to the current SIM.
# NOTE: the IMEI step pre-sets the marker before AT+CFUN=1,1; that reboot-bearing
# path is unchanged.
if [ -n "$AUTO_MODE" ] && ! _auto_sim_guard "pre-finalize"; then
    apply_status="failed"
    apply_error="superseded_sim_changed"
    write_state
    append_event "profile_failed" "Profile '$p_name' apply superseded — active SIM changed during apply" "warning"
    exit 0
fi

# Determine final status
if [ "$steps_failed" -gt 0 ] && [ "$steps_done" -gt 0 ]; then
    apply_status="partial"
    apply_error="$steps_failed step(s) failed, $steps_done succeeded"
elif [ "$steps_failed" -gt 0 ]; then
    apply_status="failed"
    apply_error="All steps failed"
else
    apply_status="complete"
fi

write_state

# Set active profile on success or partial success.
# Note: IMEI step pre-sets the active marker before AT+CFUN=1,1 (modem reboot
# may trigger a system reboot on some configs). Re-set here for the non-IMEI
# path, and clear on total failure.
if [ "$apply_status" = "complete" ] || [ "$apply_status" = "partial" ]; then
    set_active_profile "$PROFILE_ID"
    # Scenario binding side-effect (NOT a tracked apply step): arm the profile's
    # scenario schedule timer (no-op if the schedule is disabled — the helper
    # handles that internally).
    command -v scenario_install_schedule >/dev/null 2>&1 && scenario_install_schedule "$PROFILE_ID"
elif [ "$apply_status" = "failed" ]; then
    clear_active_profile
    command -v scenario_teardown_schedule >/dev/null 2>&1 && scenario_teardown_schedule
    command -v scenario_reset_to_default >/dev/null 2>&1 && scenario_reset_to_default
fi

# --- Emit network event ------------------------------------------------------
if [ "$apply_status" = "complete" ]; then
    append_event "profile_applied" "Profile '$p_name' applied successfully" "info"
elif [ "$apply_status" = "partial" ]; then
    append_event "profile_applied" "Profile '$p_name' partially applied ($steps_failed step(s) failed)" "warning"
else
    append_event "profile_failed" "Profile '$p_name' failed to apply ($steps_failed step(s) failed)" "error"
fi

qlog_info "Profile apply finished: status=$apply_status (done=$steps_done, failed=$steps_failed, skipped=$steps_skipped)"
