# =============================================================================
# HELPER: SAFE QCMD CALL
# =============================================================================
# Calls qcmd and strips the echoed AT command + trailing OK from sms_tool output.
# Returns exit codes:
#   0 = success
#   1 = modem unreachable / timeout
#   2 = command returned ERROR (but modem is reachable)

qcmd_exec() {
    local cmd="$1"
    local result

    result=$(qcmd "$cmd" 2>/dev/null)
    local exit_code=$?

    if [ $exit_code -ne 0 ] || [ -z "$result" ]; then
        qlog_warn "qcmd_exec failed: cmd=${cmd} exit=${exit_code}"
        return 1
    fi

    # Strip echoed AT command and trailing OK from sms_tool output.
    result=$(printf '%s\n' "$result" | grep -v '^AT' | grep -v '^OK$' | grep -v '^$')

    case "$result" in
        *ERROR*)
            qlog_debug "qcmd_exec AT ERROR: cmd=${cmd}"
            echo "$result"
            return 2
            ;;
    esac

    echo "$result"
    return 0
}

# =============================================================================
# SYSTEM METRICS (No modem lock needed)
# =============================================================================

update_proc_metrics() {
    # --- CPU Usage % (from /proc/stat delta) ---
    local cpu_line
    cpu_line=$(head -1 /proc/stat 2>/dev/null)
    if [ -n "$cpu_line" ]; then
        # /proc/stat format: cpu user nice system idle iowait irq softirq steal
        local cur_idle
        local cur_total
        cur_idle=$(echo "$cpu_line" | awk '{print $5}')
        cur_total=$(echo "$cpu_line" | awk '{print $2+$3+$4+$5+$6+$7+$8+$9}')

        if [ "$prev_cpu_total" -gt 0 ] 2>/dev/null; then
            local diff_idle
            local diff_total
            diff_idle=$((cur_idle - prev_cpu_idle))
            diff_total=$((cur_total - prev_cpu_total))

            if [ "$diff_total" -gt 0 ] 2>/dev/null; then
                # Integer math: (diff_total - diff_idle) * 100 / diff_total
                cpu_usage=$(( (diff_total - diff_idle) * 100 / diff_total ))
            fi
        fi

        prev_cpu_idle=$cur_idle
        prev_cpu_total=$cur_total
    fi

    # --- Memory ---
    local mem_total
    local mem_available
    mem_total=$(grep '^MemTotal:' /proc/meminfo 2>/dev/null | awk '{print $2}')
    mem_available=$(grep '^MemAvailable:' /proc/meminfo 2>/dev/null | awk '{print $2}')

    if [ -n "$mem_total" ]; then
        memory_total_mb=$((mem_total / 1024))
    else
        memory_total_mb=0
    fi

    if [ -n "$mem_available" ] && [ -n "$mem_total" ]; then
        memory_used_mb=$(( (mem_total - mem_available) / 1024 ))
    else
        memory_used_mb=0
    fi

    # --- Uptime ---
    uptime_seconds=$(cat /proc/uptime 2>/dev/null | cut -d' ' -f1 | cut -d'.' -f1)
    uptime_seconds="${uptime_seconds:-0}"

    # --- Traffic ---
    local rx_bytes=0
    local tx_bytes=0

    if [ -f /proc/net/dev ]; then
        local dev_line
        dev_line=$(grep "${NETWORK_IFACE}:" /proc/net/dev 2>/dev/null)
        if [ -n "$dev_line" ]; then
            rx_bytes=$(echo "$dev_line" | awk '{print $2}')
            tx_bytes=$(echo "$dev_line" | awk '{print $10}')
        fi
    fi

    # Calculate bytes per second using actual elapsed wall time. Dividing by
    # POLL_INTERVAL would inflate rates ~30x after any blocking event (e.g.
    # an alert send). Floor at 1 to guard against clock skew.
    local now_ts
    now_ts=$(date +%s)
    if [ "$prev_rx_bytes" -gt 0 ] 2>/dev/null && [ "$prev_traffic_ts" -gt 0 ] 2>/dev/null; then
        local elapsed
        elapsed=$((now_ts - prev_traffic_ts))
        [ "$elapsed" -lt 1 ] && elapsed=1
        rx_bytes_per_sec=$(( (rx_bytes - prev_rx_bytes) / elapsed ))
        tx_bytes_per_sec=$(( (tx_bytes - prev_tx_bytes) / elapsed ))

        [ "$rx_bytes_per_sec" -lt 0 ] 2>/dev/null && rx_bytes_per_sec=0
        [ "$tx_bytes_per_sec" -lt 0 ] 2>/dev/null && tx_bytes_per_sec=0
    fi

    prev_rx_bytes=$rx_bytes
    prev_tx_bytes=$tx_bytes
    prev_traffic_ts=$now_ts
    total_rx_bytes=$rx_bytes
    total_tx_bytes=$tx_bytes

    cpu_usage="${cpu_usage:-0}"
}

# --- System Health -----------------------------------------------------------
# Collects modem-subsystem state (sysfs) plus CPU/storage telemetry that the
# System Health card consumes. Output flows into the top-level system_health
# block of /tmp/qmanager_status.json so the CGI is a thin cache reader.
#
# Cheap reads only — no AT commands, no forks beyond awk/grep/df. Safe to run
# every Tier 1 cycle.
update_system_health() {
    # --- subsys state + state_raw -------------------------------------------
    sh_state_raw=""
    if [ -r "${SH_SUBSYS_BASE}/state" ]; then
        sh_state_raw=$(cat "${SH_SUBSYS_BASE}/state")
    fi
    if [ -z "$sh_state_raw" ]; then
        sh_state="unknown"
    else
        case "$(printf '%s' "$sh_state_raw" | tr '[:upper:]' '[:lower:]')" in
            online)  sh_state="online"  ;;
            offline) sh_state="offline" ;;
            crashed) sh_state="crashed" ;;
            *)       sh_state="unknown" ;;
        esac
    fi

    # --- crash_count (sysfs counter) ----------------------------------------
    sh_crash_count="null"
    if [ -r "${SH_SUBSYS_BASE}/crash_count" ]; then
        local _cc
        _cc=$(cat "${SH_SUBSYS_BASE}/crash_count")
        case "$_cc" in
            *[!0-9]*) sh_crash_count="null" ;;
            "")       sh_crash_count="null" ;;
            *)        sh_crash_count="$_cc" ;;
        esac
    fi

    # --- coredump_present ---------------------------------------------------
    # Match modem-subsys.sh CGI: exclude sysfs metadata pseudo-files.
    sh_coredump_present="false"
    if [ -d "$SH_RAMDUMP_DIR" ]; then
        local _dump
        _dump=$(find "$SH_RAMDUMP_DIR" -maxdepth 1 -type f -size +0 \
            ! -name dev ! -name name ! -name power \
            ! -name subsystem ! -name uevent \
            ! -name waiting_for_supplier \
            2>/dev/null | head -1)
        [ -n "$_dump" ] && sh_coredump_present="true"
    fi

    # --- crash log summary (last_crash_at + total_logged_crashes) ------------
    sh_last_crash_at="null"
    sh_total_logged_crashes=0
    if [ -f "$SH_CRASH_LOG" ] && [ -s "$SH_CRASH_LOG" ]; then
        sh_total_logged_crashes=$(jq 'length' "$SH_CRASH_LOG" 2>/dev/null) || sh_total_logged_crashes=0
        sh_last_crash_at=$(jq 'if length > 0 then last.ts else null end' "$SH_CRASH_LOG" 2>/dev/null) || sh_last_crash_at="null"
    fi

    # --- load averages (1m / 5m / 15m) --------------------------------------
    sh_load_1m="null"
    sh_load_5m="null"
    sh_load_15m="null"
    if [ -r /proc/loadavg ]; then
        read sh_load_1m sh_load_5m sh_load_15m _rest < /proc/loadavg
    fi

    # --- core_count (cache after first read — value never changes at runtime)
    if [ "$sh_core_count" = "null" ]; then
        if command -v nproc >/dev/null 2>&1; then
            sh_core_count=$(nproc)
        elif [ -r /proc/cpuinfo ]; then
            sh_core_count=$(grep -c '^processor' /proc/cpuinfo)
        fi
    fi

    # --- cpu frequency (current + max from cpufreq) -------------------------
    sh_freq_khz="null"
    if [ -r "${SH_CPUFREQ_BASE}/scaling_cur_freq" ]; then
        sh_freq_khz=$(cat "${SH_CPUFREQ_BASE}/scaling_cur_freq")
    fi
    sh_max_freq_khz="null"
    if [ -r "${SH_CPUFREQ_BASE}/scaling_max_freq" ]; then
        sh_max_freq_khz=$(cat "${SH_CPUFREQ_BASE}/scaling_max_freq")
    fi

    # --- storage (/usrdata partition) ---------------------------------------
    sh_storage_total_kb="null"
    sh_storage_used_kb="null"
    sh_storage_avail_kb="null"
    local _df_out
    _df_out=$(df -P /usrdata 2>/dev/null)
    if [ $? -eq 0 ] && [ -n "$_df_out" ]; then
        local _df_line
        _df_line=$(printf '%s\n' "$_df_out" | awk 'NR==2{print}')
        if [ -n "$_df_line" ]; then
            sh_storage_total_kb=$(printf '%s\n' "$_df_line" | awk '{print $2}')
            sh_storage_used_kb=$(printf '%s\n' "$_df_line"  | awk '{print $3}')
            sh_storage_avail_kb=$(printf '%s\n' "$_df_line" | awk '{print $4}')
            [ -z "$sh_storage_total_kb" ] && sh_storage_total_kb="null"
            [ -z "$sh_storage_used_kb"  ] && sh_storage_used_kb="null"
            [ -z "$sh_storage_avail_kb" ] && sh_storage_avail_kb="null"
        fi
    fi
}

# --- Connection Uptime -------------------------------------------------------
# Tracks how long the modem has had internet connectivity (based on ping daemon).
# Starts counting when conn_internet_available becomes "true", resets on "false".
# Holds steady (no reset) when ping data is unavailable ("null") — avoids
# resetting the timer just because the ping daemon hasn't started yet.
update_conn_uptime() {
    if [ "$conn_internet_available" = "true" ]; then
        # Internet is reachable — start or continue counting
        if [ "$conn_start_time" -eq 0 ] 2>/dev/null; then
            conn_start_time=$(date +%s)
            qlog_debug "Connection uptime timer started"
        fi
        local now
        now=$(date +%s)
        conn_uptime_seconds=$((now - conn_start_time))
    elif [ "$conn_internet_available" = "false" ]; then
        # Internet confirmed down — reset timer
        if [ "$conn_start_time" -gt 0 ] 2>/dev/null; then
            qlog_info "Connection uptime timer reset (internet lost after ${conn_uptime_seconds}s)"
        fi
        conn_start_time=0
        conn_uptime_seconds=0
    fi
    # If conn_internet_available is "null" (ping daemon not running / stale),
    # leave timer as-is — don't reset, don't count up.
}

# =============================================================================
# PERSISTENT DATA USED COUNTER (Tier 1)
# =============================================================================
# Tracks cumulative rx/tx bytes across modem resets and reboots using both
# AT+QGDCNT (LTE) and AT+QGDNRCNT (5G) modem-side counters, cross-checked
# against the kernel rmnet_ipa0 interface for divergence detection.
# State is persisted atomically to DATA_USED_FILE each tick.

# Write current du_* state to DATA_USED_FILE atomically.
write_data_used_state() {
    mkdir -p /usrdata/qmanager 2>/dev/null
    jq -n \
        --argjson schema     "$DATA_USED_SCHEMA" \
        --argjson acc_rx     "$du_accumulated_rx" \
        --argjson acc_tx     "$du_accumulated_tx" \
        --arg     sel        "$du_selected_counter" \
        --argjson prev_gd_tx "$du_prev_qgdcnt_tx" \
        --argjson prev_gd_rx "$du_prev_qgdcnt_rx" \
        --argjson prev_nr_tx "$du_prev_qgdnrcnt_tx" \
        --argjson prev_nr_rx "$du_prev_qgdnrcnt_rx" \
        --argjson prev_i_rx  "$du_prev_ipa_rx" \
        --argjson prev_i_tx  "$du_prev_ipa_tx" \
        --argjson last_upd   "$du_last_update_ts" \
        --argjson last_rst   "$du_last_reset_ts" \
        --argjson div_cnt    "$du_divergence_count" \
        --argjson modem_rst  "$du_modem_reset_count" \
        --argjson mode_xn    "$du_mode_transition_count" \
        '{
            schema:               $schema,
            accumulated_rx_bytes: $acc_rx,
            accumulated_tx_bytes: $acc_tx,
            selected_counter:     $sel,
            prev_qgdcnt_tx:       $prev_gd_tx,
            prev_qgdcnt_rx:       $prev_gd_rx,
            prev_qgdnrcnt_tx:     $prev_nr_tx,
            prev_qgdnrcnt_rx:     $prev_nr_rx,
            prev_ipa_rx:          $prev_i_rx,
            prev_ipa_tx:          $prev_i_tx,
            last_update_ts:       $last_upd,
            last_reset_ts:        $last_rst,
            divergence_count:     $div_cnt,
            modem_reset_count:    $modem_rst,
            mode_transition_count:$mode_xn
        }' > "$DATA_USED_TMP" && mv "$DATA_USED_TMP" "$DATA_USED_FILE"
}

update_data_used() {
    # Step 0: lazy-load from disk on first call
    if [ "$du_loaded" = "false" ]; then
        if [ -f "$DATA_USED_FILE" ]; then
            local _jv
            _jv=$(jq -r '
                (.accumulated_rx_bytes  // 0 | tostring) + " " +
                (.accumulated_tx_bytes  // 0 | tostring) + " " +
                (.selected_counter      // ""           ) + " " +
                (.prev_qgdcnt_tx        // 0 | tostring) + " " +
                (.prev_qgdcnt_rx        // 0 | tostring) + " " +
                (.prev_qgdnrcnt_tx      // 0 | tostring) + " " +
                (.prev_qgdnrcnt_rx      // 0 | tostring) + " " +
                (.prev_ipa_rx           // 0 | tostring) + " " +
                (.prev_ipa_tx           // 0 | tostring) + " " +
                (.last_update_ts        // 0 | tostring) + " " +
                (.last_reset_ts         // 0 | tostring) + " " +
                (.divergence_count      // 0 | tostring) + " " +
                (.modem_reset_count     // 0 | tostring) + " " +
                (.mode_transition_count // 0 | tostring)
            ' "$DATA_USED_FILE" 2>/dev/null)
            if [ -n "$_jv" ]; then
                du_accumulated_rx=$(    printf '%s' "$_jv" | awk '{print $1}')
                du_accumulated_tx=$(    printf '%s' "$_jv" | awk '{print $2}')
                du_selected_counter=$(  printf '%s' "$_jv" | awk '{print $3}')
                du_prev_qgdcnt_tx=$(    printf '%s' "$_jv" | awk '{print $4}')
                du_prev_qgdcnt_rx=$(    printf '%s' "$_jv" | awk '{print $5}')
                du_prev_qgdnrcnt_tx=$(  printf '%s' "$_jv" | awk '{print $6}')
                du_prev_qgdnrcnt_rx=$(  printf '%s' "$_jv" | awk '{print $7}')
                du_prev_ipa_rx=$(       printf '%s' "$_jv" | awk '{print $8}')
                du_prev_ipa_tx=$(       printf '%s' "$_jv" | awk '{print $9}')
                du_last_update_ts=$(    printf '%s' "$_jv" | awk '{print $10}')
                du_last_reset_ts=$(     printf '%s' "$_jv" | awk '{print $11}')
                du_divergence_count=$(  printf '%s' "$_jv" | awk '{print $12}')
                du_modem_reset_count=$( printf '%s' "$_jv" | awk '{print $13}')
                du_mode_transition_count=$(printf '%s' "$_jv" | awk '{print $14}')
            fi
        else
            # No file yet — create directory; zeroed state already set at init
            mkdir -p /usrdata/qmanager 2>/dev/null
        fi
        du_loaded=true
    fi

    # Step 1: honor user reset flag
    if [ -f "$DATA_USED_RESET_FLAG" ]; then
        du_accumulated_rx=0
        du_accumulated_tx=0
        du_last_reset_ts=$(date +%s)
        rm -f "$DATA_USED_RESET_FLAG"
        qlog_info "data_used: user reset triggered"
    fi

    # Step 2: pick counter from network_type
    local du_active
    case "$network_type" in
        LTE)          du_active="qgdcnt"   ;;
        5G-SA|5G-NSA) du_active="qgdnrcnt" ;;
        *)            return 0 ;;
    esac

    # Step 3: read /proc/net/dev rmnet_ipa0
    local ipa_rx
    local ipa_tx
    ipa_rx=0
    ipa_tx=0
    if [ -f /proc/net/dev ]; then
        local _dev_line
        _dev_line=$(grep "rmnet_ipa0:" /proc/net/dev 2>/dev/null)
        if [ -n "$_dev_line" ]; then
            ipa_rx=$(printf '%s\n' "$_dev_line" | awk '{print $2}')
            ipa_tx=$(printf '%s\n' "$_dev_line" | awk '{print $10}')
        fi
    fi
    ipa_rx="${ipa_rx:-0}"
    ipa_tx="${ipa_tx:-0}"

    # Step 3b: read the AT counter for the active mode
    local _at_resp
    if [ "$du_active" = "qgdcnt" ]; then
        _at_resp=$(qcmd_exec 'AT+QGDCNT?')
    else
        _at_resp=$(qcmd_exec 'AT+QGDNRCNT?')
    fi

    # Parse: +QGDCNT: <tx>,<rx>  or  +QGDNRCNT: <tx>,<rx>
    local _parsed
    _parsed=$(printf '%s\n' "$_at_resp" | \
        sed -n 's/^+QGD[A-Z]*CNT:[[:space:]]*\([0-9]*\),\([0-9]*\).*/\1 \2/p' | \
        head -1)
    if [ -z "$_parsed" ]; then
        # AT failure — leave all state untouched; next tick will retry
        return 0
    fi

    local current_tx
    local current_rx
    current_tx=$(printf '%s' "$_parsed" | awk '{print $1}')
    current_rx=$(printf '%s' "$_parsed" | awk '{print $2}')

    # Step 4: mode transition handling — rebase, no accumulation this tick
    if [ "$du_active" != "$du_selected_counter" ]; then
        qlog_info "data_used: counter changed ${du_selected_counter} -> ${du_active}"
        du_selected_counter="$du_active"
        du_mode_transition_count=$((du_mode_transition_count + 1))
        if [ "$du_active" = "qgdcnt" ]; then
            du_prev_qgdcnt_tx="$current_tx"
            du_prev_qgdcnt_rx="$current_rx"
        else
            du_prev_qgdnrcnt_tx="$current_tx"
            du_prev_qgdnrcnt_rx="$current_rx"
        fi
        du_prev_ipa_rx="$ipa_rx"
        du_prev_ipa_tx="$ipa_tx"
        write_data_used_state
        return 0
    fi

    # Step 5: pick prev for active counter
    local prev_tx
    local prev_rx
    if [ "$du_active" = "qgdcnt" ]; then
        prev_tx="$du_prev_qgdcnt_tx"
        prev_rx="$du_prev_qgdcnt_rx"
    else
        prev_tx="$du_prev_qgdnrcnt_tx"
        prev_rx="$du_prev_qgdnrcnt_rx"
    fi

    local delta_tx
    local delta_rx
    delta_tx=$((current_tx - prev_tx))
    delta_rx=$((current_rx - prev_rx))

    # Step 6: counter reset detection (negative delta — modem cleared its counter)
    if [ "$delta_tx" -lt 0 ] || [ "$delta_rx" -lt 0 ]; then
        qlog_info "data_used: modem-side reset detected (delta_rx=${delta_rx} delta_tx=${delta_tx})"
        du_modem_reset_count=$((du_modem_reset_count + 1))
        # Rebase only — no accumulation this tick
    else
        du_accumulated_rx=$((du_accumulated_rx + delta_rx))
        du_accumulated_tx=$((du_accumulated_tx + delta_tx))

        # Step 7: divergence check vs IPA kernel counter
        local ipa_drx
        local ipa_dtx
        ipa_drx=$((ipa_rx - du_prev_ipa_rx))
        ipa_dtx=$((ipa_tx - du_prev_ipa_tx))
        if [ "$ipa_drx" -lt 0 ]; then ipa_drx=0; fi
        if [ "$ipa_dtx" -lt 0 ]; then ipa_dtx=0; fi
        local ipa_total
        local at_total
        ipa_total=$((ipa_drx + ipa_dtx))
        at_total=$((delta_rx + delta_tx))
        if [ "$ipa_total" -gt "$DATA_USED_DIVERGENCE_MIN" ]; then
            local _diff
            _diff=$((at_total - ipa_total))
            if [ "$_diff" -lt 0 ]; then _diff=$((-_diff)); fi
            local _pct
            _pct=$((_diff * 100 / ipa_total))
            if [ "$_pct" -gt "$DATA_USED_DIVERGENCE_PCT" ]; then
                qlog_warn "data_used divergence at=${at_total}B ipa=${ipa_total}B (${_pct}%) mode=${network_type} counter=${du_active}"
                du_divergence_count=$((du_divergence_count + 1))
            fi
        fi
    fi

    # Step 8: update prev_* for next tick
    if [ "$du_active" = "qgdcnt" ]; then
        du_prev_qgdcnt_tx="$current_tx"
        du_prev_qgdcnt_rx="$current_rx"
    else
        du_prev_qgdnrcnt_tx="$current_tx"
        du_prev_qgdnrcnt_rx="$current_rx"
    fi
    du_prev_ipa_rx="$ipa_rx"
    du_prev_ipa_tx="$ipa_tx"
    du_last_update_ts=$(date +%s)
    write_data_used_state
}

# =============================================================================
# BOOT DATA COLLECTION (runs once at startup)
# =============================================================================

collect_boot_data() {
    log_info "Collecting boot-only data..."

    local result

    # =========================================================================
    # Group A: Identity reads — compound AT (7 → 1 call)
    # CVERSION, CGMM, CGSN, CIMI return bare responses (no +PREFIX:).
    # CGMM: bare model name; CGSN/CIMI: bare 15-digit numbers.
    # Order is deterministic: first 15-digit line = IMEI, second = IMSI.
    # =========================================================================
    result=$(qcmd 'AT+CVERSION;+CGMM;+CGSN;+CIMI;+QCCID;+CNUM;+QGETCAPABILITY' 2>/dev/null)

    if [ -n "$result" ]; then
        # CVERSION: prefixed lines — parsers already grep by prefix
        parse_version "$result"

        # CGMM: bare model name — the only non-numeric, non-prefixed single
        # line between the CVERSION block and the bare 15-digit numbers.
        # Extract as: first line after Authors: block that isn't blank/prefix/digits.
        boot_model=$(printf '%s\n' "$result" | tr -d '\r' | \
            grep -v '^AT' | grep -v '^OK$' | grep -v '^$' | \
            grep -v '^VERSION:' | grep -v '^Authors:' | \
            grep -v '^[0-9]' | grep -v '^+' | \
            grep -v '^[A-Z][a-z][a-z] ' | \
            head -1)

        # CGSN / CIMI: bare 15-digit numbers, order-based extraction
        boot_imei=$(printf '%s\n' "$result" | tr -d '\r' | grep -x '[0-9]\{15\}' | sed -n '1p')
        boot_imsi=$(printf '%s\n' "$result" | tr -d '\r' | grep -x '[0-9]\{15\}' | sed -n '2p')

        # QCCID: prefixed
        boot_iccid=$(printf '%s\n' "$result" | grep '+QCCID:' | sed 's/+QCCID: //g' | tr -d '\r ')

        # CNUM: prefixed
        local num
        num=$(printf '%s\n' "$result" | grep '+CNUM:' | head -1 | cut -d',' -f2 | tr -d '"' | tr -d '\r')
        [ -n "$num" ] && boot_phone_number="$num"

        # QGETCAPABILITY: prefixed (multi-line)
        parse_capability "$result"
    fi

    # --- SIM Swap Detection (boot-time, one-shot) ---
    LAST_ICCID_FILE="/etc/qmanager/last_iccid"
    SIM_SWAP_FLAG="/tmp/qmanager_sim_swap_detected"
    if [ -n "$boot_iccid" ]; then
        if [ -f "$LAST_ICCID_FILE" ]; then
            local stored_iccid
            stored_iccid=$(cat "$LAST_ICCID_FILE" 2>/dev/null | tr -d ' \r\n')
            if [ -n "$stored_iccid" ] && [ "$stored_iccid" != "$boot_iccid" ]; then
                qlog_warn "SIM SWAP DETECTED: old=...$(printf '%s' "$stored_iccid" | tail -c 4) new=...$(printf '%s' "$boot_iccid" | tail -c 4)"
                local match_name="" match_id=""
                local pf
                for pf in /etc/qmanager/profiles/*.json; do
                    [ -f "$pf" ] || continue
                    local pf_iccid
                    pf_iccid=$(jq -r '(.sim_iccid) | if . == null then empty else . end' "$pf" 2>/dev/null)
                    if [ "$pf_iccid" = "$boot_iccid" ]; then
                        match_name=$(jq -r '(.name) | if . == null then empty else . end' "$pf" 2>/dev/null)
                        match_id=$(jq -r '(.id) | if . == null then empty else . end' "$pf" 2>/dev/null)
                        break
                    fi
                done
                jq -n -c \
                    --argjson ts "$(date +%s)" \
                    --arg prev "$stored_iccid" \
                    --arg curr "$boot_iccid" \
                    --arg pid "$match_id" \
                    --arg pname "$match_name" \
                    '{detected_at:$ts,previous_iccid:$prev,current_iccid:$curr,matching_profile_id:$pid,matching_profile_name:$pname,dismissed:false}' \
                    > "$SIM_SWAP_FLAG"
                append_event "sim_swap_detected" "New SIM detected (ICCID: ...$(printf '%s' "$boot_iccid" | tail -c 4))" "info"
            fi
        fi
        printf '%s' "$boot_iccid" > "$LAST_ICCID_FILE"

        # --- Auto-deactivate profile on SIM mismatch ---
        # If the active profile was created for a different SIM, clear it so
        # the UI no longer shows a stale "Active" badge.
        local _ap_file="/etc/qmanager/active_profile"
        if [ -f "$_ap_file" ]; then
            local _ap_id _ap_iccid _ap_name
            _ap_id=$(cat "$_ap_file" 2>/dev/null | tr -d ' \r\n')
            if [ -n "$_ap_id" ] && [ -f "/etc/qmanager/profiles/${_ap_id}.json" ]; then
                _ap_iccid=$(jq -r '(.sim_iccid) | if . == null then empty else . end' "/etc/qmanager/profiles/${_ap_id}.json" 2>/dev/null)
                if [ -n "$_ap_iccid" ] && [ "$_ap_iccid" != "$boot_iccid" ]; then
                    _ap_name=$(jq -r '(.name) | if . == null then empty else . end' "/etc/qmanager/profiles/${_ap_id}.json" 2>/dev/null)
                    rm -f "$_ap_file"
                    qlog_warn "Auto-deactivated profile '$_ap_name' — SIM ICCID mismatch (profile: ...$(printf '%s' "$_ap_iccid" | tail -c 4), current: ...$(printf '%s' "$boot_iccid" | tail -c 4))"
                    append_event "profile_deactivated" "Profile '$_ap_name' auto-deactivated (SIM mismatch)" "warning"
                fi
            fi
        fi
    fi

    # =========================================================================
    # Pre-boot serving cell — needed to gate MIMO reads by network mode
    # =========================================================================
    poll_serving_cell
    sleep "$SIP_DELAY"

    # =========================================================================
    # Group B: Enables + post-enable reads
    # Enable commands (,1) are unconditional — idempotent, safe in any mode.
    # MIMO reads are gated by network_type (lte_mimo_layers crashes in SA,
    # nr5g_mimo_layers crashes in LTE/NSA).
    # =========================================================================
    local boot_cmd='AT+QCAINFO=1;+QNWCFG="lte_mimo_layers",1;+QNWCFG="nr5g_mimo_layers",1;+QNWCFG="lte_time_advance",1;+QNWCFG="nr5g_time_advance",1'
    # Append mode-appropriate MIMO read
    if [ "$network_type" = "5G-SA" ]; then
        boot_cmd="${boot_cmd}"';+QNWCFG="nr5g_mimo_layers"'
    elif [ "$network_type" = "LTE" ] || [ "$network_type" = "5G-NSA" ]; then
        boot_cmd="${boot_cmd}"';+QNWCFG="lte_mimo_layers"'
    fi
    # Remaining mode-independent reads
    boot_cmd="${boot_cmd}"';+QMAP="MPDN_RULE";+QMAP="IPPT_NAT";+QCFG="usbnet";+QMAP="DHCPV4DNS"'
    result=$(qcmd "$boot_cmd" 2>/dev/null)

    if [ -n "$result" ]; then
        # MIMO layers (parser greps for each prefix independently)
        parse_mimo "$result" "$result"

        # IP Passthrough settings (all parsers grep for their specific keywords)
        parse_ippt_mpdn_rule "$result"
        parse_ippt_nat "$result"
        parse_ippt_usbnet "$result"
        parse_ippt_dhcpv4dns "$result"
    fi

    # =========================================================================
    # LAN gateway — separate qcmd call, isolated from other compounds.
    # AT+QMAP="LANIP" is unsupported on some firmwares (e.g. older RM501);
    # running it on its own keeps that failure from affecting other reads.
    # The parser silently sets empty values when the response shape doesn't
    # match the canonical +QMAP: "LANIP",start,end,gateway form.
    # =========================================================================
    result=$(qcmd 'AT+QMAP="LANIP"' 2>/dev/null)
    if [ -n "$result" ]; then
        parse_lan_ip "$result"
    fi

    # =========================================================================
    # Supported bands — conditional (cached to /tmp across hotplug restarts)
    # On full device reboot /tmp is cleared, so queried once then cached.
    # =========================================================================
    SUPPORTED_BANDS_FILE="/tmp/qmanager_supported_bands.env"
    if [ -f "$SUPPORTED_BANDS_FILE" ]; then
        . "$SUPPORTED_BANDS_FILE"
        qlog_info "Loaded supported bands from RAM cache"
    else
        result=$(qcmd_exec 'AT+QNWPREFCFG="policy_band"')
        if [ $? -eq 0 ]; then
            parse_policy_band "$result"
            printf 'boot_supported_lte_bands="%s"\nboot_supported_nsa_nr5g_bands="%s"\nboot_supported_sa_nr5g_bands="%s"\n' \
                "$boot_supported_lte_bands" "$boot_supported_nsa_nr5g_bands" "$boot_supported_sa_nr5g_bands" \
                > "$SUPPORTED_BANDS_FILE"
            qlog_info "Supported bands cached to $SUPPORTED_BANDS_FILE"
        fi
    fi

    # =========================================================================
    # Active profile auto-apply at boot
    # =========================================================================
    # If ICCID matches a saved profile, (re-)apply all its settings.
    # The apply script skips any setting that already matches — no-op if
    # nothing drifted. Also handles SIM swap: if the old active profile was
    # deactivated above (ICCID mismatch), this finds and applies the profile
    # for the new SIM instead.
    # =========================================================================
    if [ -n "$boot_iccid" ]; then
        auto_apply_profile "$boot_iccid" "boot"
    fi

    log_info "Boot data: FW=$boot_firmware BUILD=$boot_build_date MFG=$boot_manufacturer MODEL=$boot_model"
    log_info "Boot data: IMEI=$boot_imei IMSI=$boot_imsi ICCID=$boot_iccid"
    log_info "Boot data: PHONE=$boot_phone_number CAT=$boot_lte_category MIMO=$t2_mimo"
    log_info "Boot data: LTE_BANDS=$boot_supported_lte_bands NSA_BANDS=$boot_supported_nsa_nr5g_bands SA_BANDS=$boot_supported_sa_nr5g_bands"
    log_info "Boot data: IPPT mode=$boot_ippt_mode nat=$boot_ippt_nat usb=$boot_ippt_usbnet dns=$boot_ippt_dhcpv4dns"
    log_info "Boot data: LAN ip=$boot_lan_ip gateway=$boot_lan_gateway"
}

# =============================================================================
# read_sim_identity — Re-read SIM-bound identifiers (IMSI, ICCID)
# =============================================================================
# Called from the Tier 2 force-refresh path after a user-initiated SIM slot
# swap. Only refreshes fields that actually change with the SIM card —
# leaves IMEI / model / firmware / capability alone (those are modem-bound
# and a SIM swap can't affect them).
#
# Response shape differs from collect_boot_data's compound read. Standalone CIMI
# returns a single bare 15-digit number (no IMEI prefix line to disambiguate),
# so we use `head -1` instead of `sed -n '2p'`.
# =============================================================================
read_sim_identity() {
    local result new_imsi new_iccid
    result=$(qcmd 'AT+CIMI;+QCCID' 2>/dev/null)
    [ -z "$result" ] && return 0

    new_imsi=$(printf '%s\n' "$result" | tr -d '\r' | grep -x '[0-9]\{15\}' | head -1)
    new_iccid=$(printf '%s\n' "$result" | grep '+QCCID:' | sed 's/+QCCID: //g' | tr -d '\r ')

    [ -n "$new_imsi" ] && boot_imsi="$new_imsi"
    [ -n "$new_iccid" ] && boot_iccid="$new_iccid"
}

# =============================================================================
# TIER 1: HOT DATA (every cycle)
# =============================================================================

poll_serving_cell() {
    local result
    result=$(qcmd_exec 'AT+QENG="servingcell"')
    local rc=$?

    if [ $rc -eq 0 ] || [ $rc -eq 2 ]; then
        if [ "$modem_reachable" != "true" ]; then
            qlog_state_change "modem_reachable" "false" "true"
        fi
        modem_reachable=true
        local prev_network_type="$network_type"
        local prev_lte_state="$lte_state"
        local prev_nr_state="$nr_state"
        parse_serving_cell "$result"
        # Log state transitions
        qlog_state_change "network_type" "$prev_network_type" "$network_type"
        qlog_state_change "lte_state" "$prev_lte_state" "$lte_state"
        qlog_state_change "nr_state" "$prev_nr_state" "$nr_state"
    else
        if [ "$modem_reachable" = "true" ]; then
            qlog_state_change "modem_reachable" "true" "false"
        fi
        modem_reachable=false
        system_state="degraded"
        lte_state="unknown"
        nr_state="unknown"
        errors="modem_timeout"
        log_warn "Modem unreachable during serving cell poll"
    fi
}

# =============================================================================
# TIER 1.5: PER-ANTENNA SIGNAL (every 5 cycles / 10s)
# =============================================================================
# Three AT commands (~200ms each = ~600ms total modem lock per cycle).
# Writes latest values to state vars AND appends to NDJSON history file.

poll_per_antenna_signal() {
    # Compound AT: fetch all per-antenna signal data in one call
    local result
    result=$(qcmd 'AT+QRSRP;+QRSRQ;+QSINR' 2>/dev/null)

    if [ -n "$result" ]; then
        parse_qrsrp "$result"
        parse_qrsrq "$result"
        parse_qsinr "$result"
    fi

    # Append to signal history
    append_signal_history
}

# Append current per-antenna values as one NDJSON line to the history file.
# Capped at SIGNAL_HISTORY_MAX lines (~30 min at 10s intervals).
append_signal_history() {
    local ts
    ts=$(date +%s)

    jq -n -c \
        --argjson ts "$ts" \
        --argjson lte_rsrp "$sig_lte_rsrp" \
        --argjson lte_rsrq "$sig_lte_rsrq" \
        --argjson lte_sinr "$sig_lte_sinr" \
        --argjson nr_rsrp "$sig_nr_rsrp" \
        --argjson nr_rsrq "$sig_nr_rsrq" \
        --argjson nr_sinr "$sig_nr_sinr" \
        '{ts:$ts, lte_rsrp:$lte_rsrp, lte_rsrq:$lte_rsrq, lte_sinr:$lte_sinr,
         nr_rsrp:$nr_rsrp, nr_rsrq:$nr_rsrq, nr_sinr:$nr_sinr}' >> "$SIGNAL_HISTORY_FILE"

    # Trim to max entries
    local count
    count=$(wc -l < "$SIGNAL_HISTORY_FILE" 2>/dev/null || echo 0)
    if [ "$count" -gt "$SIGNAL_HISTORY_MAX" ]; then
        local tmp="${SIGNAL_HISTORY_FILE}.tmp"
        tail -n "$SIGNAL_HISTORY_MAX" "$SIGNAL_HISTORY_FILE" > "$tmp"
        mv "$tmp" "$SIGNAL_HISTORY_FILE"
    fi
}

# Append current ping/connectivity stats as one NDJSON line to the ping history file.
# Capped at PING_HISTORY_MAX lines (~24h at 10s intervals).
# Uses conn_ variables already populated by read_ping_data().
append_ping_history() {
    local ts
    ts=$(date +%s)

    jq -n -c \
        --argjson ts "$ts" \
        --argjson lat "${conn_latency:-null}" \
        --argjson avg "${conn_avg_latency:-null}" \
        --argjson min "${conn_min_latency:-null}" \
        --argjson max "${conn_max_latency:-null}" \
        --argjson loss "${conn_packet_loss:-0}" \
        --argjson jit "${conn_jitter:-null}" \
        '{ts:$ts,lat:$lat,avg:$avg,min:$min,max:$max,loss:$loss,jit:$jit}' >> "$PING_HISTORY_FILE"

    # Trim to max entries
    local count
    count=$(wc -l < "$PING_HISTORY_FILE" 2>/dev/null || echo 0)
    if [ "$count" -gt "$PING_HISTORY_MAX" ]; then
        local tmp="${PING_HISTORY_FILE}.tmp"
        tail -n "$PING_HISTORY_MAX" "$PING_HISTORY_FILE" > "$tmp"
        mv "$tmp" "$PING_HISTORY_FILE"
    fi
}

# =============================================================================
# TIER 2: WARM DATA (every N cycles)
# =============================================================================

poll_tier2() {
    local result

    # Compound AT: status queries in one call.
    # CPIN? is last — it can ERROR when SIM is absent; placing it last
    # ensures earlier responses (QTEMP, COPS, QUIMSLOT, CNUM) are preserved
    # even if the modem aborts on CPIN ERROR.
    result=$(qcmd 'AT+QTEMP;+COPS?;+QUIMSLOT?;+CNUM;+CPIN?' 2>/dev/null)

    if [ -n "$result" ]; then
        parse_temperature "$result"
        parse_carrier "$result"
        parse_sim_slot "$result"

        # Phone number refresh (may change on SIM swap)
        local num
        num=$(printf '%s\n' "$result" | grep '+CNUM:' | head -1 | cut -d',' -f2 | tr -d '"' | tr -d '\r')
        [ -n "$num" ] && boot_phone_number="$num"

        # SIM status — extract CPIN line specifically (parse_sim_status uses
        # case matching, not grep, so pass only the relevant line)
        local cpin_line
        cpin_line=$(printf '%s\n' "$result" | grep '+CPIN:' | head -1)
        if [ -n "$cpin_line" ]; then
            parse_sim_status "$cpin_line"
        elif printf '%s\n' "$result" | grep -q 'CME ERROR'; then
            t2_sim_status="error"
            errors="sim_not_inserted"
        fi
    fi
    sleep "$SIP_DELAY"

    # Network info split into 3 independent groups so that LTE errors
    # (in SA mode) or NR errors (in LTE-only) cannot kill the whole chain.

    # --- Group 1: APN + WAN IPs (always safe, mode-independent) ---
    result=$(qcmd 'AT+CGCONTRDP;+QMAP="WWAN"' 2>/dev/null)
    if [ -n "$result" ]; then
        if printf '%s\n' "$result" | grep -q '+CGCONTRDP:'; then
            parse_cgcontrdp "$result"
        else
            t2_apn="" ; t2_primary_dns="" ; t2_secondary_dns=""
        fi
        if printf '%s\n' "$result" | grep -q '+QMAP:'; then
            parse_wan_ip "$result"
        else
            t2_wan_ipv4="" ; t2_wan_ipv6=""
        fi
    else
        t2_apn="" ; t2_primary_dns="" ; t2_secondary_dns=""
        t2_wan_ipv4="" ; t2_wan_ipv6=""
    fi
    sleep "$SIP_DELAY"

    # --- Group 2: NR timing + MIMO ---
    # nr5g_mimo_layers is only valid in SA mode (crashes/errors in LTE & NSA)
    local nr_cmd='AT+QNWCFG="nr5g_time_advance"'
    if [ "$network_type" = "5G-SA" ]; then
        nr_cmd="${nr_cmd}"';+QNWCFG="nr5g_mimo_layers"'
    fi
    result=$(qcmd "$nr_cmd" 2>/dev/null)
    if [ -n "$result" ]; then
        parse_time_advance "$result"
        parse_mimo "" "$result"
    else
        nr_ta=""
    fi
    sleep "$SIP_DELAY"

    # --- Group 3: LTE timing + MIMO ---
    # lte_mimo_layers is valid in LTE and NSA (crashes/errors in SA)
    local lte_cmd='AT+QNWCFG="lte_time_advance"'
    if [ "$network_type" = "LTE" ] || [ "$network_type" = "5G-NSA" ]; then
        lte_cmd="${lte_cmd}"';+QNWCFG="lte_mimo_layers"'
    fi
    result=$(qcmd "$lte_cmd" 2>/dev/null)
    if [ -n "$result" ]; then
        parse_time_advance "$result"
        parse_mimo "$result" ""
    else
        lte_ta=""
    fi
}

# =============================================================================
# SERVICE QUALITY ASSESSMENT
# =============================================================================

determine_service_status() {
    # Reset every cycle so a stale value cannot survive ambiguous inputs.
    service_status="unknown"

    if [ "$modem_reachable" != "true" ]; then
        return
    fi

    if [ "$t2_sim_status" = "not_inserted" ] || [ "$t2_sim_status" = "error" ]; then
        service_status="sim_error"
        return
    fi

    if { [ "$lte_state" = "disconnected" ] || [ "$lte_state" = "unknown" ]; } && [ "$nr_state" != "connected" ]; then
        service_status="no_service"
        return
    fi

    if [ "$lte_state" = "searching" ]; then
        service_status="searching"
        return
    fi

    # Pick the primary RSRP — NR if connected, else LTE
    local primary_rsrp=""
    if [ "$nr_state" = "connected" ] && [ -n "$nr_rsrp" ]; then
        primary_rsrp=$nr_rsrp
    elif [ -n "$lte_rsrp" ]; then
        primary_rsrp=$lte_rsrp
    fi

    if [ -n "$primary_rsrp" ] && [ "$primary_rsrp" -gt -100 ] 2>/dev/null; then
        service_status="optimal"
    elif [ -n "$primary_rsrp" ]; then
        service_status="connected"
    elif [ "$lte_state" = "connected" ] || [ "$nr_state" = "connected" ]; then
        # Registered but signal not yet sampled this cycle — keep "connected"
        # rather than the default "unknown".
        service_status="connected"
    fi
}

# =============================================================================
# CONNECTIVITY DATA (from ping daemon — no modem lock needed)
# =============================================================================

PING_CACHE="/tmp/qmanager_ping.json"
PING_HISTORY_RAW="/tmp/qmanager_ping_history"   # flat-file ring buffer from ping daemon
PING_STALE_THRESHOLD=10  # seconds before ping data is considered stale
PING_DAEMON_STALE_EVENT_THRESHOLD=60  # seconds before emitting ping_daemon_stale

read_ping_data() {
    # Reset to defaults if ping file missing or stale
    if [ ! -f "$PING_CACHE" ]; then
        conn_internet_available="null"
        conn_status="unknown"
        conn_latency="null"
        conn_avg_latency="null"
        conn_min_latency="null"
        conn_max_latency="null"
        conn_jitter="null"
        conn_packet_loss=0
        conn_ping_target=""
        conn_history="[]"
        conn_history_interval=0
        conn_during_recovery="false"
        conn_connectivity="unknown"
        conn_limited_reason="null"
        conn_down_reason="null"
        conn_streak_limited=0
        conn_profile="unknown"
        conn_fail_secs=0
        conn_recover_secs=0
        conn_intercept_secs=0
        _ping_stale_since=0
        return
    fi

    # Check staleness (ping daemon may have crashed)
    local ping_ts
    local now
    local age
    ping_ts=$(jq -r '.timestamp | if . == null then empty else tostring end' "$PING_CACHE" 2>/dev/null)
    now=$(date +%s)

    if [ -n "$ping_ts" ]; then
        age=$((now - ping_ts))
        if [ "$age" -gt "$PING_STALE_THRESHOLD" ]; then
            qlog_warn "Ping data stale (age=${age}s), marking unknown"
            conn_internet_available="null"
            conn_status="unknown"
            conn_latency="null"
            conn_avg_latency="null"
            conn_min_latency="null"
            conn_max_latency="null"
            conn_jitter="null"
            conn_packet_loss=0
            conn_history="[]"
            conn_history_interval=0
            conn_during_recovery="false"
            conn_connectivity="unknown"
            conn_limited_reason="null"
            conn_down_reason="null"
            conn_streak_limited=0
            conn_profile="unknown"
            conn_fail_secs=0
            conn_recover_secs=0
            conn_intercept_secs=0

            # Track sustained staleness: emit a one-shot event when the
            # ping daemon has been stale long enough that alerts could be
            # silently missing. _ping_stale_since=0 means "not currently
            # tracking"; a positive value is the epoch when staleness began.
            if [ "$_ping_stale_since" -eq 0 ] 2>/dev/null; then
                _ping_stale_since=$now
            else
                local stale_dur=$((now - _ping_stale_since))
                if [ "$stale_dur" -ge "$PING_DAEMON_STALE_EVENT_THRESHOLD" ] 2>/dev/null; then
                    append_event "ping_daemon_stale" \
                        "Ping daemon stale for ${stale_dur}s — alerts may be suppressed" \
                        "warning"
                    # Restart the window from now so the next emission only
                    # fires after another full threshold has elapsed. Storing
                    # a real epoch (rather than a future-offset value) keeps
                    # the variable's invariant easy to reason about: it is
                    # always either 0 (healthy) or the epoch at which we
                    # last either started tracking or emitted a heartbeat.
                    _ping_stale_since=$now
                fi
            fi
            return
        fi
    fi
    # Fresh data — clear any stale-tracking state.
    _ping_stale_since=0

    # Step A: Extract slim scalar fields from ping JSON (single jq call)
    # ping.json no longer carries stats/history — those are computed here from raw file.
    # Phase 2 additions: tri-state connectivity + runtime profile/threshold fields.
    local _pdata
    _pdata=$(jq -r '[
        ((.reachable) | if . == null then "null" else tostring end),
        ((.last_rtt_ms) | if . == null then "null" else tostring end),
        ((.during_recovery) | if . == null then "false" else tostring end),
        ((.interval_sec) | if . == null then "5" else tostring end),
        (.targets[0] // ""),
        (.connectivity // "unknown"),
        ((.limited_reason) | if . == null then "null" else tostring end),
        ((.down_reason) | if . == null then "null" else tostring end),
        ((.streak_limited) | if . == null then "0" else tostring end),
        (.profile // "unknown"),
        ((.fail_secs) | if . == null then "0" else tostring end),
        ((.recover_secs) | if . == null then "0" else tostring end),
        ((.intercept_secs) | if . == null then "0" else tostring end)
    ] | @tsv' "$PING_CACHE" 2>/dev/null)

    conn_internet_available=$(printf '%s' "$_pdata" | cut -f1)
    conn_latency=$(printf '%s' "$_pdata" | cut -f2)
    conn_during_recovery=$(printf '%s' "$_pdata" | cut -f3)
    conn_history_interval=$(printf '%s' "$_pdata" | cut -f4)
    conn_ping_target=$(printf '%s' "$_pdata" | cut -f5)
    conn_connectivity=$(printf '%s' "$_pdata" | cut -f6)
    conn_limited_reason=$(printf '%s' "$_pdata" | cut -f7)
    conn_down_reason=$(printf '%s' "$_pdata" | cut -f8)
    conn_streak_limited=$(printf '%s' "$_pdata" | cut -f9)
    conn_profile=$(printf '%s' "$_pdata" | cut -f10)
    conn_fail_secs=$(printf '%s' "$_pdata" | cut -f11)
    conn_recover_secs=$(printf '%s' "$_pdata" | cut -f12)
    conn_intercept_secs=$(printf '%s' "$_pdata" | cut -f13)

    # Step B: Single awk pass — only when ping timestamp changed (saves awk fork every 2s)
    # With ping daemon at 5s, awk runs ~every 5s instead of every cycle.
    if [ "$ping_ts" != "$_last_ping_ts" ]; then
        _last_ping_ts="$ping_ts"

        local _ha=""
        if [ -s "$PING_HISTORY_RAW" ]; then
            _ha=$(awk '
            BEGIN { n=0; lost=0; nv=0; have=0; sum=0; jsum=0 }
            {
                n++; arr[n]=$0
                if ($0=="null") { lost++ }
                else {
                    val=$0+0; sum+=val; nv++
                    if (!have||val<min) min=val
                    if (!have||val>max) max=val
                    have=1
                    if (nv>1) { d=val-prev; if(d<0)d=-d; jsum+=d }
                    prev=val
                }
            }
            END {
                if (nv>0)
                    printf "%.1f|%.1f|%.1f|%.1f|%d|", min,sum/nv,max,(nv>1?jsum/(nv-1):0),int(lost*100/n)
                else
                    printf "null|null|null|null|%d|", (n>0?100:0)
                printf "["
                for(i=1;i<=n;i++) { if(i>1) printf ","; printf "%s",arr[i] }
                printf "]\n"
            }' "$PING_HISTORY_RAW")
        fi

        if [ -n "$_ha" ]; then
            local _rest="$_ha"
            conn_min_latency="${_rest%%|*}";  _rest="${_rest#*|}"
            conn_avg_latency="${_rest%%|*}";  _rest="${_rest#*|}"
            conn_max_latency="${_rest%%|*}";  _rest="${_rest#*|}"
            conn_jitter="${_rest%%|*}";       _rest="${_rest#*|}"
            conn_packet_loss="${_rest%%|*}";  _rest="${_rest#*|}"
            conn_history="${_rest}"           # remaining is "[json_array]"
        else
            conn_min_latency="null"
            conn_avg_latency="null"
            conn_max_latency="null"
            conn_jitter="null"
            conn_packet_loss=0
            conn_history="[]"
        fi
    fi
    # (if ts unchanged: cached conn_* stats remain valid)

    # Derive connectivity status from ping data + modem state
    if [ "$conn_during_recovery" = "true" ]; then
        conn_status="recovery"
    elif [ "$conn_internet_available" = "true" ]; then
        local loss="${conn_packet_loss:-0}"
        if [ "$loss" -ge 10 ] 2>/dev/null; then
            conn_status="degraded"
        else
            conn_status="connected"
        fi
    elif [ "$conn_internet_available" = "false" ]; then
        conn_status="disconnected"
    else
        conn_status="unknown"
    fi

    # Sanitize: ensure numeric fields are valid
    case "$conn_packet_loss" in
        *[!0-9]*|'') conn_packet_loss=0 ;;
    esac
    case "$conn_history_interval" in
        *[!0-9]*|'') conn_history_interval=5 ;;
    esac
}

# =============================================================================
# MODEM CRASH WATCHER (sysfs subsys0/crash_count)
# =============================================================================
# Runs once at startup (crash_watcher_init) and once per Tier 1 cycle
# (crash_watcher_check). Uses two global state variables declared above:
#   _crash_watcher_enabled  — false if sysfs path absent (RM551E / unknown hw)
#   _last_crash_count       — last-known value; updated on every change

crash_watcher_init() {
    if [ ! -f "$_CRASH_COUNT_SYSFS" ]; then
        qlog_warn "modem crash watcher disabled — sysfs path absent"
        _crash_watcher_enabled=false
        return
    fi
    _crash_watcher_enabled=true

    local current_count
    current_count=$(cat "$_CRASH_COUNT_SYSFS" 2>/dev/null | tr -d '[:space:]')
    # If unreadable even though the file exists, treat as 0 (safe baseline)
    case "$current_count" in
        ''|*[!0-9]*) current_count=0 ;;
    esac

    if [ -f "$_CRASH_SIDECAR" ]; then
        # Load persisted last-known count
        local saved
        saved=$(cat "$_CRASH_SIDECAR" 2>/dev/null | tr -d '[:space:]')
        case "$saved" in
            ''|*[!0-9]*) saved=0 ;;
        esac
        _last_crash_count=$saved
        qlog_info "crash watcher: loaded sidecar last_count=${_last_crash_count} current=${current_count}"
    else
        # First run — establish baseline without writing a crash log entry
        _last_crash_count=$current_count
        printf '%s\n' "$current_count" > "${_CRASH_SIDECAR}.tmp" && \
            mv "${_CRASH_SIDECAR}.tmp" "$_CRASH_SIDECAR"
        qlog_info "crash watcher: baseline established count=${current_count}"
    fi
}

crash_watcher_check() {
    # Fast-exit if disabled (sysfs absent — RM551E or unsupported hw)
    if [ "$_crash_watcher_enabled" != "true" ]; then
        return
    fi

    local new_count
    new_count=$(cat "$_CRASH_COUNT_SYSFS" 2>/dev/null | tr -d '[:space:]')
    case "$new_count" in
        ''|*[!0-9]*)
            # Unreadable this cycle — skip silently (transient sysfs glitch)
            return
            ;;
    esac

    # No change — common case, returns immediately
    if [ "$new_count" -eq "$_last_crash_count" ] 2>/dev/null; then
        return
    fi

    # Counter decreased — modem reset zeroed the counter; re-baseline silently
    if [ "$new_count" -lt "$_last_crash_count" ] 2>/dev/null; then
        qlog_info "crash watcher: counter reset (${_last_crash_count} → ${new_count}), re-baselining"
        _last_crash_count=$new_count
        printf '%s\n' "$new_count" > "${_CRASH_SIDECAR}.tmp" && \
            mv "${_CRASH_SIDECAR}.tmp" "$_CRASH_SIDECAR"
        return
    fi

    # Counter incremented — log the crash event
    local prev_count="$_last_crash_count"
    local ts
    ts=$(date +%s)

    # Read modem state from sysfs; lowercase-normalise; default "unknown"
    local raw_state modem_state_at_event
    raw_state=$(cat "$_CRASH_STATE_SYSFS" 2>/dev/null | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')
    case "$raw_state" in
        online|offline|crashed) modem_state_at_event="$raw_state" ;;
        *) modem_state_at_event="unknown" ;;
    esac

    # Uptime is already populated by update_proc_metrics earlier this cycle
    local uptime_now="${uptime_seconds:-0}"

    # Build the new entry using jq (no hand-rolled JSON)
    local new_entry
    new_entry=$(jq -n \
        --argjson ts "$ts" \
        --argjson prev "$prev_count" \
        --argjson new  "$new_count" \
        --arg     state "$modem_state_at_event" \
        --argjson uptime "$uptime_now" \
        '{ts: $ts, previous_count: $prev, new_count: $new,
          modem_state_at_event: $state, uptime_at_event_seconds: $uptime}')

    if [ -z "$new_entry" ]; then
        qlog_error "crash watcher: jq failed to build entry — skipping log write"
        return
    fi

    # Read existing log (treat missing/empty/corrupt file as empty array)
    local existing_log
    existing_log=$(jq '.' "$_CRASH_LOG" 2>/dev/null)
    case "$existing_log" in
        '['*) : ;;   # valid array — keep as-is
        *)    existing_log='[]' ;;
    esac

    # Append new entry and cap at 100 most-recent, then atomic-write
    printf '%s\n' "$existing_log" | \
        jq --argjson entry "$new_entry" \
           '. + [$entry] | if length > 100 then .[-100:] else . end' \
        > "${_CRASH_LOG}.tmp" && \
        mv "${_CRASH_LOG}.tmp" "$_CRASH_LOG"

    # Update sidecar atomically
    printf '%s\n' "$new_count" > "${_CRASH_SIDECAR}.tmp" && \
        mv "${_CRASH_SIDECAR}.tmp" "$_CRASH_SIDECAR"

    _last_crash_count=$new_count
    qlog_info "crash watcher: modem crash detected (${prev_count} → ${new_count}), state=${modem_state_at_event}"
}

# =============================================================================
# WATCHCAT & SIM STATE READERS
# =============================================================================

# Watchcat state variables (populated by read_watchcat_state)
wc_enabled="false"
wc_state="disabled"
wc_current_tier=0
wc_failure_count=0
wc_last_recovery_time="null"
wc_last_recovery_tier="null"
wc_total_recoveries=0
wc_cooldown_remaining=0
wc_reboots_this_hour=0
WATCHCAT_CACHE="/tmp/qmanager_watchcat.json"

# SIM failover state variables
sim_fo_active="false"
sim_fo_original_slot="null"
sim_fo_current_slot="null"
sim_fo_switched_at="null"
SIM_FAILOVER_FILE="/tmp/qmanager_sim_failover"

# SIM swap detection state variables
sim_swap_detected="false"
sim_swap_profile_id=""
sim_swap_profile_name=""

read_watchcat_state() {
    if [ ! -f "$WATCHCAT_CACHE" ]; then
        wc_enabled="false"; wc_state="disabled"
        return
    fi
    local _wdata
    _wdata=$(jq -r '[
        ((.enabled) | if . == null then "false" else tostring end),
        (.state // "unknown"),
        ((.current_tier) | if . == null then "0" else tostring end),
        ((.failure_count) | if . == null then "0" else tostring end),
        ((.last_recovery_time) | if . == null then "null" else tostring end),
        ((.last_recovery_tier) | if . == null then "null" else tostring end),
        ((.total_recoveries) | if . == null then "0" else tostring end),
        ((.cooldown_remaining) | if . == null then "0" else tostring end),
        ((.reboots_this_hour) | if . == null then "0" else tostring end)
    ] | @tsv' "$WATCHCAT_CACHE" 2>/dev/null)

    [ -z "$_wdata" ] && return

    wc_enabled=$(printf '%s' "$_wdata" | cut -f1)
    wc_state=$(printf '%s' "$_wdata" | cut -f2)
    wc_current_tier=$(printf '%s' "$_wdata" | cut -f3)
    wc_failure_count=$(printf '%s' "$_wdata" | cut -f4)
    wc_last_recovery_time=$(printf '%s' "$_wdata" | cut -f5)
    wc_last_recovery_tier=$(printf '%s' "$_wdata" | cut -f6)
    wc_total_recoveries=$(printf '%s' "$_wdata" | cut -f7)
    wc_cooldown_remaining=$(printf '%s' "$_wdata" | cut -f8)
    wc_reboots_this_hour=$(printf '%s' "$_wdata" | cut -f9)
}

read_sim_state() {
    # SIM swap flag (boot-time, changes rarely)
    sim_swap_detected="false"
    sim_swap_profile_id=""
    sim_swap_profile_name=""
    if [ -f "$SIM_SWAP_FLAG" ]; then
        local _swap_data
        _swap_data=$(jq -r '[
            ((.dismissed) | if . == null then "false" else tostring end),
            (.matching_profile_id // ""),
            (.matching_profile_name // "")
        ] | @tsv' "$SIM_SWAP_FLAG" 2>/dev/null)
        local _dismissed
        _dismissed=$(printf '%s' "$_swap_data" | cut -f1)
        if [ "$_dismissed" != "true" ]; then
            sim_swap_detected="true"
            sim_swap_profile_id=$(printf '%s' "$_swap_data" | cut -f2)
            sim_swap_profile_name=$(printf '%s' "$_swap_data" | cut -f3)
        fi
    fi

    # SIM failover state (written by watchcat Tier 3)
    sim_fo_active="false"
    sim_fo_original_slot="null"
    sim_fo_current_slot="null"
    sim_fo_switched_at="null"
    if [ -f "$SIM_FAILOVER_FILE" ]; then
        local _fo_data
        _fo_data=$(jq -r '[
            ((.active) | if . == null then "false" else tostring end),
            ((.original_slot) | if . == null then "null" else tostring end),
            ((.current_slot) | if . == null then "null" else tostring end),
            ((.switched_at) | if . == null then "null" else tostring end)
        ] | @tsv' "$SIM_FAILOVER_FILE" 2>/dev/null)
        sim_fo_active=$(printf '%s' "$_fo_data" | cut -f1)
        sim_fo_original_slot=$(printf '%s' "$_fo_data" | cut -f2)
        sim_fo_current_slot=$(printf '%s' "$_fo_data" | cut -f3)
        sim_fo_switched_at=$(printf '%s' "$_fo_data" | cut -f4)
    fi
}

# =============================================================================
# JSON CACHE WRITER
# =============================================================================

write_cache() {
    local timestamp
    timestamp=$(date +%s)

    # Build errors array
    local errors_json="[]"
    if [ -n "$errors" ]; then
        errors_json=$(jq -n --arg e "$errors" '[$e]')
    fi

    jq -n \
        --argjson timestamp "$timestamp" \
        --arg system_state "$system_state" \
        --argjson modem_reachable "$modem_reachable" \
        --argjson errors "$errors_json" \
        --argjson cfun "${t1_cfun:-1}" \
        --arg net_type "${network_type:-LTE}" \
        --argjson sim_slot "${t2_sim_slot:-1}" \
        --arg carrier "$t2_carrier" \
        --arg service_status "$service_status" \
        --argjson ca_active "$t2_ca_active" \
        --argjson ca_count "$t2_ca_count" \
        --argjson nr_ca_active "$t2_nr_ca_active" \
        --argjson nr_ca_count "$t2_nr_ca_count" \
        --argjson total_bw "${t2_total_bandwidth_mhz:-0}" \
        --arg bw_details "$t2_bandwidth_details" \
        --argjson cc "$t2_carrier_components" \
        --arg apn "$t2_apn" \
        --arg wan4 "$t2_wan_ipv4" \
        --arg wan6 "$t2_wan_ipv6" \
        --arg dns1 "$t2_primary_dns" \
        --arg dns2 "$t2_secondary_dns" \
        --arg lte_st "$lte_state" \
        --arg lte_b "$lte_band" \
        --argjson lte_earfcn "${lte_earfcn:-null}" \
        --argjson lte_bw "${lte_bandwidth:-null}" \
        --argjson lte_pci "${lte_pci:-null}" \
        --argjson lte_cid "${lte_cell_id:-null}" \
        --argjson lte_enb "${lte_enodeb_id:-null}" \
        --argjson lte_sec "${lte_sector_id:-null}" \
        --argjson lte_tac "${lte_tac:-null}" \
        --argjson lte_rsrp "${lte_rsrp:-null}" \
        --argjson lte_rsrq "${lte_rsrq:-null}" \
        --argjson lte_sinr "${lte_sinr:-null}" \
        --argjson lte_rssi "${lte_rssi:-null}" \
        --argjson lte_ta "${lte_ta:-null}" \
        --arg nr_st "$nr_state" \
        --arg nr_b "$nr_band" \
        --argjson nr_arfcn "${nr_arfcn:-null}" \
        --argjson nr_pci "${nr_pci:-null}" \
        --argjson nr_cid "${nr_cell_id:-null}" \
        --argjson nr_enb "${nr_enodeb_id:-null}" \
        --argjson nr_sec "${nr_sector_id:-null}" \
        --argjson nr_tac "${nr_tac:-null}" \
        --argjson nr_rsrp "${nr_rsrp:-null}" \
        --argjson nr_rsrq "${nr_rsrq:-null}" \
        --argjson nr_sinr "${nr_sinr:-null}" \
        --argjson nr_scs "${nr_scs:-null}" \
        --argjson nr_ta "${nr_ta:-null}" \
        --argjson slr "$sig_lte_rsrp" \
        --argjson slq "$sig_lte_rsrq" \
        --argjson sls "$sig_lte_sinr" \
        --argjson snr "$sig_nr_rsrp" \
        --argjson snq "$sig_nr_rsrq" \
        --argjson sns "$sig_nr_sinr" \
        --argjson temp "${t2_temperature:-null}" \
        --argjson cpu "${cpu_usage:-0}" \
        --argjson mem_used "${memory_used_mb:-0}" \
        --argjson mem_total "${memory_total_mb:-0}" \
        --argjson uptime "${uptime_seconds:-0}" \
        --argjson conn_up "${conn_uptime_seconds:-0}" \
        --arg firmware "$boot_firmware" \
        --arg build_date "$boot_build_date" \
        --arg mfr "$boot_manufacturer" \
        --arg model "$boot_model" \
        --arg imei "$boot_imei" \
        --arg imsi "$boot_imsi" \
        --arg iccid "$boot_iccid" \
        --arg phone "$boot_phone_number" \
        --arg lte_cat "$boot_lte_category" \
        --arg mimo "$t2_mimo" \
        --arg sup_lte "$boot_supported_lte_bands" \
        --arg sup_nsa "$boot_supported_nsa_nr5g_bands" \
        --arg sup_sa "$boot_supported_sa_nr5g_bands" \
        --arg ippt_mode "$boot_ippt_mode" \
        --arg ippt_mac  "$boot_ippt_mac" \
        --arg ippt_nat  "$boot_ippt_nat" \
        --arg ippt_usb  "$boot_ippt_usbnet" \
        --arg ippt_dns  "$boot_ippt_dhcpv4dns" \
        --arg lan_ip    "$boot_lan_ip" \
        --arg lan_gw    "$boot_lan_gateway" \
        --argjson rx_rate "${rx_bytes_per_sec:-0}" \
        --argjson tx_rate "${tx_bytes_per_sec:-0}" \
        --argjson rx_total "${total_rx_bytes:-0}" \
        --argjson tx_total "${total_tx_bytes:-0}" \
        --argjson inet "${conn_internet_available:-null}" \
        --arg conn_st "$conn_status" \
        --argjson lat "${conn_latency:-null}" \
        --argjson avg_lat "${conn_avg_latency:-null}" \
        --argjson min_lat "${conn_min_latency:-null}" \
        --argjson max_lat "${conn_max_latency:-null}" \
        --argjson jit "${conn_jitter:-null}" \
        --argjson pkt_loss "${conn_packet_loss:-0}" \
        --arg ping_tgt "$conn_ping_target" \
        --argjson lat_hist "${conn_history:-[]}" \
        --argjson hist_int "${conn_history_interval:-2}" \
        --argjson hist_size "${CONN_HISTORY_SIZE:-60}" \
        --argjson during_rec "${conn_during_recovery:-false}" \
        --arg conn_state "$conn_connectivity" \
        --argjson conn_limited_reason "$conn_limited_reason" \
        --arg conn_down_reason "$conn_down_reason" \
        --argjson conn_streak_limited "$conn_streak_limited" \
        --arg conn_profile "$conn_profile" \
        --argjson conn_fail_secs "$conn_fail_secs" \
        --argjson conn_recover_secs "$conn_recover_secs" \
        --argjson conn_intercept_secs "$conn_intercept_secs" \
        --argjson wc_enabled "${wc_enabled:-false}" \
        --arg wc_state "${wc_state:-disabled}" \
        --argjson wc_tier "${wc_current_tier:-0}" \
        --argjson wc_failures "${wc_failure_count:-0}" \
        --argjson wc_last_time "${wc_last_recovery_time:-null}" \
        --argjson wc_last_tier "${wc_last_recovery_tier:-null}" \
        --argjson wc_total "${wc_total_recoveries:-0}" \
        --argjson wc_cooldown "${wc_cooldown_remaining:-0}" \
        --argjson wc_reboots "${wc_reboots_this_hour:-0}" \
        --argjson sf_active "${sim_fo_active:-false}" \
        --argjson sf_orig "${sim_fo_original_slot:-null}" \
        --argjson sf_curr "${sim_fo_current_slot:-null}" \
        --argjson sf_time "${sim_fo_switched_at:-null}" \
        --argjson ss_detected "${sim_swap_detected:-false}" \
        --arg ss_profile_id "$sim_swap_profile_id" \
        --arg ss_profile_name "$sim_swap_profile_name" \
        --arg     sh_state          "$sh_state" \
        --arg     sh_state_raw      "$sh_state_raw" \
        --argjson sh_crash_count    "${sh_crash_count:-null}" \
        --argjson sh_coredump       "${sh_coredump_present:-false}" \
        --argjson sh_last_crash_at  "${sh_last_crash_at:-null}" \
        --argjson sh_total_crashes  "${sh_total_logged_crashes:-0}" \
        --argjson sh_load_1m        "${sh_load_1m:-null}" \
        --argjson sh_load_5m        "${sh_load_5m:-null}" \
        --argjson sh_load_15m       "${sh_load_15m:-null}" \
        --argjson sh_core_count     "${sh_core_count:-null}" \
        --argjson sh_freq_khz       "${sh_freq_khz:-null}" \
        --argjson sh_max_freq_khz   "${sh_max_freq_khz:-null}" \
        --argjson sh_st_total_kb    "${sh_storage_total_kb:-null}" \
        --argjson sh_st_used_kb     "${sh_storage_used_kb:-null}" \
        --argjson sh_st_avail_kb    "${sh_storage_avail_kb:-null}" \
        --argjson du_acc_rx         "${du_accumulated_rx:-0}" \
        --argjson du_acc_tx         "${du_accumulated_tx:-0}" \
        --arg     du_sel            "${du_selected_counter:-}" \
        --argjson du_last_upd       "${du_last_update_ts:-0}" \
        --argjson du_last_rst       "${du_last_reset_ts:-0}" \
        --argjson du_div            "${du_divergence_count:-0}" \
        --argjson du_modem_rst      "${du_modem_reset_count:-0}" \
        --argjson du_mode_xn        "${du_mode_transition_count:-0}" \
        '{
            timestamp: $timestamp,
            system_state: $system_state,
            modem_reachable: $modem_reachable,
            last_successful_poll: $timestamp,
            errors: $errors,
            network: {
                cfun: $cfun,
                type: $net_type,
                sim_slot: $sim_slot,
                carrier: $carrier,
                service_status: $service_status,
                ca_active: $ca_active,
                ca_count: $ca_count,
                nr_ca_active: $nr_ca_active,
                nr_ca_count: $nr_ca_count,
                total_bandwidth_mhz: $total_bw,
                bandwidth_details: $bw_details,
                carrier_components: $cc,
                apn: $apn,
                wan_ipv4: $wan4,
                wan_ipv6: $wan6,
                primary_dns: $dns1,
                secondary_dns: $dns2,
                device_ip: $lan_ip,
                lan_gateway: $lan_gw
            },
            lte: {
                state: $lte_st, band: $lte_b,
                earfcn: $lte_earfcn, bandwidth: $lte_bw,
                pci: $lte_pci, cell_id: $lte_cid,
                enodeb_id: $lte_enb, sector_id: $lte_sec, tac: $lte_tac,
                rsrp: $lte_rsrp, rsrq: $lte_rsrq,
                sinr: $lte_sinr, rssi: $lte_rssi, ta: $lte_ta
            },
            nr: {
                state: $nr_st, band: $nr_b,
                arfcn: $nr_arfcn, pci: $nr_pci,
                cell_id: $nr_cid, enodeb_id: $nr_enb,
                sector_id: $nr_sec, tac: $nr_tac,
                rsrp: $nr_rsrp, rsrq: $nr_rsrq,
                sinr: $nr_sinr, scs: $nr_scs, ta: $nr_ta
            },
            signal_per_antenna: {
                lte_rsrp: $slr, lte_rsrq: $slq, lte_sinr: $sls,
                nr_rsrp: $snr, nr_rsrq: $snq, nr_sinr: $sns
            },
            device: {
                temperature: $temp, cpu_usage: $cpu,
                memory_used_mb: $mem_used, memory_total_mb: $mem_total,
                uptime_seconds: $uptime, conn_uptime_seconds: $conn_up,
                firmware: $firmware, build_date: $build_date,
                manufacturer: $mfr, model: $model,
                imei: $imei, imsi: $imsi,
                iccid: $iccid, phone_number: $phone,
                lte_category: $lte_cat, mimo: $mimo,
                supported_lte_bands: $sup_lte,
                supported_nsa_nr5g_bands: $sup_nsa,
                supported_sa_nr5g_bands: $sup_sa,
                ippt_mode: $ippt_mode,
                ippt_mac: $ippt_mac,
                ippt_nat: $ippt_nat,
                ippt_usbnet: $ippt_usb,
                ippt_dhcpv4dns: $ippt_dns
            },
            traffic: {
                rx_bytes_per_sec: $rx_rate, tx_bytes_per_sec: $tx_rate,
                total_rx_bytes: $rx_total, total_tx_bytes: $tx_total
            },
            data_used: {
                accumulated_rx_bytes: $du_acc_rx,
                accumulated_tx_bytes: $du_acc_tx,
                selected_counter:     $du_sel,
                last_update_ts:       $du_last_upd,
                last_reset_ts:        $du_last_rst,
                divergence_count:     $du_div,
                modem_reset_count:    $du_modem_rst,
                mode_transition_count: $du_mode_xn
            },
            connectivity: {
                internet_available: $inet, status: $conn_st,
                latency_ms: $lat, avg_latency_ms: $avg_lat,
                min_latency_ms: $min_lat, max_latency_ms: $max_lat,
                jitter_ms: $jit, packet_loss_pct: $pkt_loss,
                ping_target: $ping_tgt, latency_history: $lat_hist,
                history_interval_sec: $hist_int, history_size: $hist_size,
                during_recovery: $during_rec,
                state: $conn_state,
                limited_reason: $conn_limited_reason,
                down_reason: (if $conn_down_reason == "null" then null else $conn_down_reason end),
                streak_limited: $conn_streak_limited,
                profile: $conn_profile,
                fail_secs: $conn_fail_secs,
                recover_secs: $conn_recover_secs,
                intercept_secs: $conn_intercept_secs
            },
            watchcat: {
                enabled: $wc_enabled, state: $wc_state,
                current_tier: $wc_tier, failure_count: $wc_failures,
                last_recovery_time: $wc_last_time,
                last_recovery_tier: $wc_last_tier,
                total_recoveries: $wc_total,
                cooldown_remaining: $wc_cooldown,
                reboots_this_hour: $wc_reboots
            },
            sim_failover: {
                active: $sf_active,
                original_slot: $sf_orig,
                current_slot: $sf_curr,
                switched_at: $sf_time
            },
            sim_swap: {
                detected: $ss_detected,
                matching_profile_id: $ss_profile_id,
                matching_profile_name: $ss_profile_name
            },
            system_health: {
                state:                $sh_state,
                state_raw:            (if $sh_state_raw == "" then null else $sh_state_raw end),
                crash_count:          $sh_crash_count,
                coredump_present:     $sh_coredump,
                last_crash_at:        $sh_last_crash_at,
                total_logged_crashes: $sh_total_crashes,
                cpu: {
                    load_1m:      $sh_load_1m,
                    load_5m:      $sh_load_5m,
                    load_15m:     $sh_load_15m,
                    core_count:   $sh_core_count,
                    usage_pct:    $cpu,
                    freq_khz:     $sh_freq_khz,
                    max_freq_khz: $sh_max_freq_khz
                },
                memory: (
                    if $mem_total > 0 then
                        { total_kb: ($mem_total * 1024),
                          used_kb:  ($mem_used * 1024),
                          available_kb: (($mem_total - $mem_used) * 1024) }
                    else null end
                ),
                storage: (
                    if $sh_st_total_kb == null then null else
                        { mount: "/usrdata",
                          total_kb: $sh_st_total_kb,
                          used_kb:  $sh_st_used_kb,
                          available_kb: $sh_st_avail_kb }
                    end
                )
            }
        }' > "$CACHE_TMP"

    mv "$CACHE_TMP" "$CACHE_FILE"
}

# =============================================================================
# POLL CYCLE
# =============================================================================

poll_cycle() {
    # --- LONG_FLAG expiry guard ---
    # If a CGI sets the flag and dies before clearing it, the poller would
    # otherwise stay in scan_in_progress mode forever. Treat any flag older
    # than LONG_FLAG_MAX_AGE seconds as stale and remove it.
    if [ -f "$LONG_FLAG" ]; then
        local _lf_mtime _lf_now _lf_age
        _lf_mtime=$(stat -c %Y "$LONG_FLAG" 2>/dev/null || echo 0)
        _lf_now=$(date +%s)
        _lf_age=$((_lf_now - _lf_mtime))
        if [ "$_lf_age" -gt "$LONG_FLAG_MAX_AGE" ] 2>/dev/null; then
            qlog_warn "LONG_FLAG stale (age=${_lf_age}s > ${LONG_FLAG_MAX_AGE}s) — removing"
            rm -f "$LONG_FLAG"
        fi
    fi
    # --- end LONG_FLAG expiry guard ---

    # --- Ping-based checks FIRST (no modem dependency) ---
    # These must run before AT commands in case qcmd blocks on serial I/O.
    update_proc_metrics
    update_system_health
    read_ping_data
    check_email_alert
    check_sms_alert

    if [ -f "$LONG_FLAG" ]; then
        if [ "$system_state" != "scan_in_progress" ]; then
            qlog_state_change "system_state" "$system_state" "scan_in_progress"
        fi
        system_state="scan_in_progress"
        # Ping history (every Tier 1.5 interval — 10s)
        if [ $((cycle_count % TIER1_5_EVERY)) -eq 0 ]; then
            append_ping_history
        fi
        update_conn_uptime
        write_cache
        return
    fi

    errors=""
    system_state="normal"

    # Tier 1 (AT commands — may block if modem is unresponsive)
    poll_serving_cell
    sleep "$SIP_DELAY"

    # Carrier Aggregation — QCAINFO reporting enabled at boot (Group B).
    local ca_result
    ca_result=$(qcmd_exec 'AT+QCAINFO')
    if [ $? -eq 0 ] && [ -n "$ca_result" ]; then
        parse_ca_info "$ca_result"
    else
        t2_ca_active=false
        t2_ca_count=0
        t2_nr_ca_active=false
        t2_nr_ca_count=0
        t2_total_bandwidth_mhz=0
        t2_bandwidth_details=""
        t2_carrier_components="[]"
    fi
    sleep "$SIP_DELAY"

    # Tier 1 — modem crash watcher (pure sysfs reads; no-op when disabled)
    crash_watcher_check

    # Persistent Data Used counter (Tier 1) — network_type is set by
    # poll_serving_cell above; must run before write_cache below.
    update_data_used

    # Tier 1.5 (per-antenna signal history + watchcat state)
    if [ $((cycle_count % TIER1_5_EVERY)) -eq 0 ]; then
        poll_per_antenna_signal
        sleep "$SIP_DELAY"
        read_watchcat_state
    fi

    # Tier 2 (warm data + SIM state + CFUN)
    # Honor the on-demand refresh flag so a SIM-slot change picks up the
    # new carrier name within ~2s instead of up to ~30s.
    force_tier2=false
    if [ -f "$TIER2_REFRESH_FLAG" ]; then
        force_tier2=true
        rm -f "$TIER2_REFRESH_FLAG"
    fi
    if [ "$force_tier2" = "true" ] || [ $((cycle_count % TIER2_EVERY)) -eq 0 ]; then
        poll_tier2
        read_sim_state
        [ "$force_tier2" = "true" ] && read_sim_identity

        # CFUN — standalone query (compound commands timeout in CFUN=0).
        # Cadence is Tier 2 because airplane-mode toggles are user-driven and rare.
        local cfun_result
        cfun_result=$(qcmd 'AT+CFUN?' 2>/dev/null)
        if [ -n "$cfun_result" ]; then
            local cfun_val
            cfun_val=$(printf '%s\n' "$cfun_result" | grep '+CFUN:' | head -1 | tr -d '\r' | awk -F': ' '{print $2}' | tr -d ' ')
            [ -n "$cfun_val" ] && t1_cfun="$cfun_val"
        fi
        sleep "$SIP_DELAY"
    fi

    # Ping history (every Tier 1.5 interval — 10s)
    if [ $((cycle_count % TIER1_5_EVERY)) -eq 0 ]; then
        append_ping_history
    fi
    update_conn_uptime
    determine_service_status
    detect_events
    write_cache

    cycle_count=$((cycle_count + 1))
}

# =============================================================================
# MAIN
# =============================================================================

main() {
    local cycle_start cycle_end cycle_duration

    qlog_info "========================================"
    qlog_info "QManager Poller starting"
    qlog_info "Config: interval=${POLL_INTERVAL}s tier2_every=${TIER2_EVERY} iface=${NETWORK_IFACE}"
    qlog_info "Log level: ${QLOG_LEVEL:-INFO}"
    qlog_info "========================================"

    collect_boot_data
    update_proc_metrics
    update_system_health
    email_alerts_init
    sms_alerts_init
    restore_event_state
    crash_watcher_init
    write_cache

    qlog_info "Boot data collected, entering poll loop"

    while true; do
        cycle_start=$(date +%s)
        poll_cycle
        cycle_end=$(date +%s)
        cycle_duration=$((cycle_end - cycle_start))
        if [ "$cycle_duration" -gt "$CYCLE_TIME_BUDGET" ]; then
            qlog_warn "poll_cycle exceeded budget: ${cycle_duration}s > ${CYCLE_TIME_BUDGET}s"
        fi
        sleep "$POLL_INTERVAL"
    done
}

main "$@"
