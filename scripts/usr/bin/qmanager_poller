DATA_USED_TMP="/usrdata/qmanager/data_used.json.tmp"
DATA_USED_RESET_FLAG="/tmp/qmanager_data_used_reset"
DATA_USED_DIVERGENCE_PCT=15        # warn threshold (%) — looser than 5% because
                                    # IPA and AT counters are read ~80ms apart
                                    # within a tick; per-tick deltas during
                                    # bursty traffic can legitimately differ
                                    # by 5–10%. NSA undercounting (the case we
                                    # actually want to catch) shows ~50%.
DATA_USED_DIVERGENCE_MIN=100000    # bytes; only run divergence check when the
                                    # IPA delta this tick is at least 100KB.
                                    # Smaller windows are too noisy for per-
                                    # tick comparison and produce false warns.
DATA_USED_SCHEMA=1

