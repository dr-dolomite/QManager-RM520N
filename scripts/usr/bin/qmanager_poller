#!/bin/sh
# =============================================================================
# qmanager_poller — QManager Background Poller Daemon
# =============================================================================
# Continuously gathers modem data and system metrics, writes to the
# JSON state cache at /tmp/qmanager_status.json.
#
# Strategy: "Sip, Don't Gulp"
#   - Acquire lock → run ONE AT command → release → sleep → repeat
#   - Leaves gaps for terminal/watchdog to access the modem
#
# Tiers:
#   Tier 1 (Hot):    Every cycle (~2s)  — AT+QENG="servingcell", /proc reads
#   Tier 1.5 (Signal): Every 5 cycles (10s) — AT+QRSRP, AT+QRSRQ, AT+QSINR
#   Tier 2 (Warm):   Every 15 cycles    — AT+QTEMP, AT+COPS?, AT+CPIN?, AT+QUIMSLOT?,
#                                         AT+QCAINFO, AT+QNWCFG="*_time_advance"
#   Boot-only:     Once at startup    — AT+CVERSION, AT+CGSN, AT+CIMI, AT+QCCID,
#                                       AT+CNUM, AT+QGETCAPABILITY, AT+QNWCFG="lte_mimo_layers"
#
# Libraries (sourced at startup):
#   /usr/lib/qmanager/qlog.sh      — Centralized logging
#   /usr/lib/qmanager/parse_at.sh  — AT command response parsers
#   /usr/lib/qmanager/events.sh    — Network event detection
#
# Install location: /usr/bin/qmanager_poller
# =============================================================================

# --- Configuration -----------------------------------------------------------
CACHE_FILE="/tmp/qmanager_status.json"
CACHE_TMP="/tmp/qmanager_status.json.tmp"
LONG_FLAG="/tmp/qmanager_long_running"
POLL_INTERVAL=2        # seconds between Tier 1 cycles
TIER1_5_EVERY=5        # Tier 1.5 (per-antenna signal) runs every N cycles (10s)
TIER2_EVERY=15         # Tier 2 runs every N cycles
NETWORK_IFACE="wwan0"  # Network interface for traffic stats
SIP_DELAY=0.1          # Delay between AT commands (seconds)

# Signal history (NDJSON file for chart data)
SIGNAL_HISTORY_FILE="/tmp/qmanager_signal_history.json"
SIGNAL_HISTORY_MAX=180 # 30 min at 10s intervals

# --- State Variables ---------------------------------------------------------
cycle_count=0

# --- Event Detection State ---------------------------------------------------
EVENTS_FILE="/tmp/qmanager_events.json"
MAX_EVENTS=50
events_initialized=false

# Previous state for change detection (prefixed prev_ev_ to avoid collision)
prev_ev_network_type=""
prev_ev_lte_band=""
prev_ev_lte_pci=""
prev_ev_nr_band=""
prev_ev_nr_pci=""
prev_ev_nr_state=""
prev_ev_modem_reachable=""
prev_ev_internet=""
prev_ev_ca_active=""
prev_ev_ca_count=""
prev_ev_nr_ca_active=""
prev_ev_nr_ca_count=""
prev_ev_service_status=""

# Boot-only data (populated once)
boot_firmware=""
boot_build_date=""
boot_manufacturer=""
boot_imei=""
boot_imsi=""
boot_iccid=""
boot_phone_number=""
boot_lte_category=""
boot_mimo=""

# Tier 2 data (updated periodically)
t2_temperature=""
t2_carrier=""
t2_sim_status=""
t2_sim_slot="1"
t2_ca_active=false
t2_ca_count=0
t2_nr_ca_active=false
t2_nr_ca_count=0

# Tier 1 data (updated every cycle)
lte_state="unknown"
lte_band=""
lte_earfcn=""
lte_bandwidth=""
lte_pci=""
lte_rsrp=""
lte_rsrq=""
lte_sinr=""
lte_rssi=""

nr_state="unknown"
nr_band=""
nr_arfcn=""
nr_pci=""
nr_rsrp=""
nr_rsrq=""
nr_sinr=""
nr_scs=""

lte_ta=""
nr_ta=""

# Network state
network_type=""
service_status="unknown"
system_state="normal"
modem_reachable=true

# Error tracking
errors=""

# Traffic tracking
prev_rx_bytes=0
prev_tx_bytes=0
rx_bytes_per_sec=0
tx_bytes_per_sec=0

# CPU tracking (from /proc/stat)
prev_cpu_idle=0
prev_cpu_total=0

# Data usage tracking
total_rx_bytes=0
total_tx_bytes=0

# Connectivity (from ping daemon)
conn_internet_available="null"
conn_status="unknown"
conn_latency="null"
conn_avg_latency="null"
conn_min_latency="null"
conn_max_latency="null"
conn_jitter="null"
conn_packet_loss=0
conn_ping_target=""
conn_history="[]"
conn_history_interval=2
conn_history_size=60
conn_during_recovery="false"

# History size constant (must match ping daemon)
CONN_HISTORY_SIZE=60

# Connection uptime tracking
conn_uptime_seconds=0
conn_start_time=0

# System metrics
cpu_usage=0
memory_used_mb=0
memory_total_mb=0
uptime_seconds=0

# Per-antenna signal data (Tier 1.5 — JSON array strings)
sig_lte_rsrp="[null,null,null,null]"
sig_lte_rsrq="[null,null,null,null]"
sig_lte_sinr="[null,null,null,null]"
sig_nr_rsrp="[null,null,null,null]"
sig_nr_rsrq="[null,null,null,null]"
sig_nr_sinr="[null,null,null,null]"

# =============================================================================
# LIBRARY LOADING
# =============================================================================

# Logging library
. /usr/lib/qmanager/qlog.sh 2>/dev/null || {
    # Fallback if logging library not found
    qlog_init() { :; }
    qlog_debug() { :; }
    qlog_info() { :; }
    qlog_warn() { :; }
    qlog_error() { :; }
    qlog_at_cmd() { :; }
    qlog_lock() { :; }
    qlog_state_change() { :; }
}
qlog_init "poller"

# Backward-compatible aliases (used throughout this script)
log_info()  { qlog_info  "$1"; }
log_warn()  { qlog_warn  "$1"; }
log_error() { qlog_error "$1"; }

# AT command parsers
. /usr/lib/qmanager/parse_at.sh 2>/dev/null || {
    log_error "FATAL: Failed to load parse_at.sh"
    exit 1
}

# Event detection
. /usr/lib/qmanager/events.sh 2>/dev/null || {
    log_error "FATAL: Failed to load events.sh"
    exit 1
}

# =============================================================================
# HELPER: SAFE QCMD CALL
# =============================================================================
# Calls qcmd and strips the echoed AT command + trailing OK from sms_tool output.
# Returns exit codes:
#   0 = success
#   1 = modem unreachable / timeout
#   2 = command returned ERROR (but modem is reachable)

qcmd_exec() {
    local cmd="$1"
    local result

    result=$(qcmd "$cmd" 2>/dev/null)
    local exit_code=$?

    if [ $exit_code -ne 0 ] || [ -z "$result" ]; then
        qlog_warn "qcmd_exec failed: cmd=${cmd} exit=${exit_code}"
        return 1
    fi

    # Strip echoed AT command and trailing OK from sms_tool output.
    result=$(printf '%s\n' "$result" | grep -v '^AT' | grep -v '^OK$' | grep -v '^$')

    case "$result" in
        *ERROR*)
            qlog_debug "qcmd_exec AT ERROR: cmd=${cmd}"
            echo "$result"
            return 2
            ;;
    esac

    echo "$result"
    return 0
}

# =============================================================================
# SYSTEM METRICS (No modem lock needed)
# =============================================================================

update_proc_metrics() {
    # --- CPU Usage % (from /proc/stat delta) ---
    local cpu_line
    cpu_line=$(head -1 /proc/stat 2>/dev/null)
    if [ -n "$cpu_line" ]; then
        # /proc/stat format: cpu user nice system idle iowait irq softirq steal
        local cur_idle cur_total
        cur_idle=$(echo "$cpu_line" | awk '{print $5}')
        cur_total=$(echo "$cpu_line" | awk '{print $2+$3+$4+$5+$6+$7+$8+$9}')

        if [ "$prev_cpu_total" -gt 0 ] 2>/dev/null; then
            local diff_idle diff_total
            diff_idle=$((cur_idle - prev_cpu_idle))
            diff_total=$((cur_total - prev_cpu_total))

            if [ "$diff_total" -gt 0 ] 2>/dev/null; then
                # Integer math: (diff_total - diff_idle) * 100 / diff_total
                cpu_usage=$(( (diff_total - diff_idle) * 100 / diff_total ))
            fi
        fi

        prev_cpu_idle=$cur_idle
        prev_cpu_total=$cur_total
    fi

    # --- Memory ---
    local mem_total mem_available
    mem_total=$(grep '^MemTotal:' /proc/meminfo 2>/dev/null | awk '{print $2}')
    mem_available=$(grep '^MemAvailable:' /proc/meminfo 2>/dev/null | awk '{print $2}')

    if [ -n "$mem_total" ]; then
        memory_total_mb=$((mem_total / 1024))
    else
        memory_total_mb=0
    fi

    if [ -n "$mem_available" ] && [ -n "$mem_total" ]; then
        memory_used_mb=$(( (mem_total - mem_available) / 1024 ))
    else
        memory_used_mb=0
    fi

    # --- Uptime ---
    uptime_seconds=$(cat /proc/uptime 2>/dev/null | cut -d' ' -f1 | cut -d'.' -f1)
    uptime_seconds="${uptime_seconds:-0}"

    # --- Traffic ---
    local rx_bytes=0
    local tx_bytes=0

    if [ -f /proc/net/dev ]; then
        local dev_line
        dev_line=$(grep "${NETWORK_IFACE}:" /proc/net/dev 2>/dev/null)
        if [ -n "$dev_line" ]; then
            rx_bytes=$(echo "$dev_line" | awk '{print $2}')
            tx_bytes=$(echo "$dev_line" | awk '{print $10}')
        fi
    fi

    # Calculate bytes per second
    if [ "$prev_rx_bytes" -gt 0 ] 2>/dev/null; then
        rx_bytes_per_sec=$(( (rx_bytes - prev_rx_bytes) / POLL_INTERVAL ))
        tx_bytes_per_sec=$(( (tx_bytes - prev_tx_bytes) / POLL_INTERVAL ))

        [ "$rx_bytes_per_sec" -lt 0 ] 2>/dev/null && rx_bytes_per_sec=0
        [ "$tx_bytes_per_sec" -lt 0 ] 2>/dev/null && tx_bytes_per_sec=0
    fi

    prev_rx_bytes=$rx_bytes
    prev_tx_bytes=$tx_bytes
    total_rx_bytes=$rx_bytes
    total_tx_bytes=$tx_bytes

    cpu_usage="${cpu_usage:-0}"
}

# --- Connection Uptime -------------------------------------------------------
# Tracks how long the modem has had internet connectivity (based on ping daemon).
# Starts counting when conn_internet_available becomes "true", resets on "false".
# Holds steady (no reset) when ping data is unavailable ("null") — avoids
# resetting the timer just because the ping daemon hasn't started yet.
update_conn_uptime() {
    if [ "$conn_internet_available" = "true" ]; then
        # Internet is reachable — start or continue counting
        if [ "$conn_start_time" -eq 0 ] 2>/dev/null; then
            conn_start_time=$(date +%s)
            qlog_debug "Connection uptime timer started"
        fi
        local now
        now=$(date +%s)
        conn_uptime_seconds=$((now - conn_start_time))
    elif [ "$conn_internet_available" = "false" ]; then
        # Internet confirmed down — reset timer
        if [ "$conn_start_time" -gt 0 ] 2>/dev/null; then
            qlog_info "Connection uptime timer reset (internet lost after ${conn_uptime_seconds}s)"
        fi
        conn_start_time=0
        conn_uptime_seconds=0
    fi
    # If conn_internet_available is "null" (ping daemon not running / stale),
    # leave timer as-is — don't reset, don't count up.
}

# =============================================================================
# BOOT DATA COLLECTION (runs once at startup)
# =============================================================================

collect_boot_data() {
    log_info "Collecting boot-only data..."

    local result

    # Firmware version + build date + manufacturer — AT+CVERSION
    result=$(qcmd_exec 'AT+CVERSION')
    if [ $? -eq 0 ]; then
        parse_version "$result"
    fi
    sleep "$SIP_DELAY"

    # IMEI — AT+CGSN
    result=$(qcmd_exec 'AT+CGSN')
    if [ $? -eq 0 ]; then
        boot_imei=$(printf '%s\n' "$result" | grep -v '^$' | head -1 | tr -d '\r')
    fi
    sleep "$SIP_DELAY"

    # IMSI — AT+CIMI
    result=$(qcmd_exec 'AT+CIMI')
    if [ $? -eq 0 ]; then
        boot_imsi=$(printf '%s\n' "$result" | grep -v '^$' | head -1 | tr -d '\r')
    fi
    sleep "$SIP_DELAY"

    # ICCID — AT+QCCID
    result=$(qcmd_exec 'AT+QCCID')
    if [ $? -eq 0 ]; then
        boot_iccid=$(printf '%s\n' "$result" | grep '+QCCID:' | sed 's/+QCCID: //g' | tr -d '\r ')
    fi
    sleep "$SIP_DELAY"

    # Phone number — AT+CNUM
    result=$(qcmd_exec 'AT+CNUM')
    if [ $? -eq 0 ]; then
        boot_phone_number=$(printf '%s\n' "$result" | grep '+CNUM:' | head -1 | cut -d',' -f2 | tr -d '"' | tr -d '\r')
    fi
    sleep "$SIP_DELAY"

    # LTE Category — AT+QGETCAPABILITY
    result=$(qcmd_exec 'AT+QGETCAPABILITY')
    if [ $? -eq 0 ]; then
        parse_capability "$result"
    fi
    sleep "$SIP_DELAY"

    # MIMO layers — AT+QNWCFG="lte_mimo_layers"
    result=$(qcmd_exec 'AT+QNWCFG="lte_mimo_layers"')
    if [ $? -eq 0 ]; then
        parse_mimo "$result"
    fi

    # Enable Timing Advance reporting (one-time, persists until modem reboot)
    qcmd_exec 'AT+QNWCFG="lte_time_advance",1' >/dev/null 2>&1
    sleep "$SIP_DELAY"
    qcmd_exec 'AT+QNWCFG="nr_time_advance",1' >/dev/null 2>&1
    sleep "$SIP_DELAY"

    log_info "Boot data: FW=$boot_firmware BUILD=$boot_build_date MFG=$boot_manufacturer"
    log_info "Boot data: IMEI=$boot_imei IMSI=$boot_imsi ICCID=$boot_iccid"
    log_info "Boot data: PHONE=$boot_phone_number CAT=$boot_lte_category MIMO=$boot_mimo"
}

# =============================================================================
# TIER 1: HOT DATA (every cycle)
# =============================================================================

poll_serving_cell() {
    local result
    result=$(qcmd_exec 'AT+QENG="servingcell"')
    local rc=$?

    if [ $rc -eq 0 ] || [ $rc -eq 2 ]; then
        if [ "$modem_reachable" != "true" ]; then
            qlog_state_change "modem_reachable" "false" "true"
        fi
        modem_reachable=true
        local prev_network_type="$network_type"
        local prev_lte_state="$lte_state"
        local prev_nr_state="$nr_state"
        parse_serving_cell "$result"
        # Log state transitions
        qlog_state_change "network_type" "$prev_network_type" "$network_type"
        qlog_state_change "lte_state" "$prev_lte_state" "$lte_state"
        qlog_state_change "nr_state" "$prev_nr_state" "$nr_state"
    else
        if [ "$modem_reachable" = "true" ]; then
            qlog_state_change "modem_reachable" "true" "false"
        fi
        modem_reachable=false
        system_state="degraded"
        lte_state="unknown"
        nr_state="unknown"
        errors="modem_timeout"
        log_warn "Modem unreachable during serving cell poll"
    fi
}

# =============================================================================
# TIER 1.5: PER-ANTENNA SIGNAL (every 5 cycles / 10s)
# =============================================================================
# Three AT commands (~200ms each = ~600ms total modem lock per cycle).
# Writes latest values to state vars AND appends to NDJSON history file.

poll_per_antenna_signal() {
    local result

    # AT+QRSRP — per-antenna RSRP
    result=$(qcmd_exec 'AT+QRSRP')
    [ $? -eq 0 ] && parse_qrsrp "$result"
    sleep "$SIP_DELAY"

    # AT+QRSRQ — per-antenna RSRQ
    result=$(qcmd_exec 'AT+QRSRQ')
    [ $? -eq 0 ] && parse_qrsrq "$result"
    sleep "$SIP_DELAY"

    # AT+QSINR — per-antenna SINR
    result=$(qcmd_exec 'AT+QSINR')
    [ $? -eq 0 ] && parse_qsinr "$result"

    # Append to signal history
    append_signal_history
}

# Append current per-antenna values as one NDJSON line to the history file.
# Capped at SIGNAL_HISTORY_MAX lines (~30 min at 10s intervals).
append_signal_history() {
    local ts
    ts=$(date +%s)

    printf '{"ts":%d,"lte_rsrp":%s,"lte_rsrq":%s,"lte_sinr":%s,"nr_rsrp":%s,"nr_rsrq":%s,"nr_sinr":%s}\n' \
        "$ts" "$sig_lte_rsrp" "$sig_lte_rsrq" "$sig_lte_sinr" \
        "$sig_nr_rsrp" "$sig_nr_rsrq" "$sig_nr_sinr" >> "$SIGNAL_HISTORY_FILE"

    # Trim to max entries
    local count
    count=$(wc -l < "$SIGNAL_HISTORY_FILE" 2>/dev/null || echo 0)
    if [ "$count" -gt "$SIGNAL_HISTORY_MAX" ]; then
        local tmp="${SIGNAL_HISTORY_FILE}.tmp"
        tail -n "$SIGNAL_HISTORY_MAX" "$SIGNAL_HISTORY_FILE" > "$tmp"
        mv "$tmp" "$SIGNAL_HISTORY_FILE"
    fi
}

# =============================================================================
# TIER 2: WARM DATA (every N cycles)
# =============================================================================

poll_tier2() {
    local result

    # Temperature — AT+QTEMP
    result=$(qcmd_exec 'AT+QTEMP')
    [ $? -eq 0 ] && parse_temperature "$result"
    sleep "$SIP_DELAY"

    # Carrier — AT+COPS?
    result=$(qcmd_exec 'AT+COPS?')
    [ $? -eq 0 ] && parse_carrier "$result"
    sleep "$SIP_DELAY"

    # SIM status — AT+CPIN?
    result=$(qcmd_exec 'AT+CPIN?')
    if [ $? -eq 0 ]; then
        parse_sim_status "$result"
    elif [ $? -eq 2 ]; then
        t2_sim_status="error"
        errors="sim_not_inserted"
    fi
    sleep "$SIP_DELAY"

    # SIM slot — AT+QUIMSLOT?
    result=$(qcmd_exec 'AT+QUIMSLOT?')
    [ $? -eq 0 ] && parse_sim_slot "$result"
    sleep "$SIP_DELAY"

    # Phone number refresh (may change on SIM swap)
    result=$(qcmd_exec 'AT+CNUM')
    if [ $? -eq 0 ]; then
        local num
        num=$(printf '%s\n' "$result" | grep '+CNUM:' | head -1 | cut -d',' -f2 | tr -d '"' | tr -d '\r')
        [ -n "$num" ] && boot_phone_number="$num"
    fi
    sleep "$SIP_DELAY"

    # Carrier Aggregation — AT+QCAINFO=1;+QCAINFO;+QCAINFO=0
    result=$(qcmd_exec 'AT+QCAINFO=1;+QCAINFO;+QCAINFO=0')
    if [ $? -eq 0 ]; then
        parse_ca_info "$result"
    else
        t2_ca_active=false
        t2_ca_count=0
        t2_nr_ca_active=false
        t2_nr_ca_count=0
    fi
    sleep "$SIP_DELAY"

    # Timing Advance — LTE (query only, enabled at boot)
    result=$(qcmd_exec 'AT+QNWCFG="lte_time_advance"')
    if [ $? -eq 0 ]; then
        parse_time_advance "$result"
    else
        lte_ta=""
    fi
    sleep "$SIP_DELAY"

    # Timing Advance — NR (query only, will ERROR when no 5G active)
    result=$(qcmd_exec 'AT+QNWCFG="nr_time_advance"')
    if [ $? -eq 0 ]; then
        parse_time_advance "$result"
    else
        nr_ta=""
    fi
}

# =============================================================================
# SERVICE QUALITY ASSESSMENT
# =============================================================================

determine_service_status() {
    if [ "$modem_reachable" != "true" ]; then
        service_status="unknown"
        return
    fi

    if [ "$t2_sim_status" = "not_inserted" ] || [ "$t2_sim_status" = "error" ]; then
        service_status="sim_error"
        return
    fi

    if [ "$lte_state" = "disconnected" ] && [ "$nr_state" != "connected" ]; then
        service_status="no_service"
        return
    fi

    if [ "$lte_state" = "searching" ]; then
        service_status="searching"
        return
    fi

    # If we have signal values, assess quality
    local primary_rsrp=""
    if [ "$nr_state" = "connected" ] && [ -n "$nr_rsrp" ]; then
        primary_rsrp=$nr_rsrp
    elif [ -n "$lte_rsrp" ]; then
        primary_rsrp=$lte_rsrp
    fi

    if [ -n "$primary_rsrp" ] && [ "$primary_rsrp" -gt -100 ] 2>/dev/null; then
        service_status="optimal"
    elif [ -n "$primary_rsrp" ]; then
        service_status="connected"
    fi

    # If still idle but registered on a network, show connected
    if [ "$service_status" = "idle" ]; then
        service_status="connected"
    fi
}

# =============================================================================
# CONNECTIVITY DATA (from ping daemon — no modem lock needed)
# =============================================================================

PING_CACHE="/tmp/qmanager_ping.json"
PING_STALE_THRESHOLD=10  # seconds before ping data is considered stale

read_ping_data() {
    # Reset to defaults if ping file missing or stale
    if [ ! -f "$PING_CACHE" ]; then
        conn_internet_available="null"
        conn_status="unknown"
        conn_latency="null"
        conn_avg_latency="null"
        conn_min_latency="null"
        conn_max_latency="null"
        conn_jitter="null"
        conn_packet_loss=0
        conn_ping_target=""
        conn_history="[]"
        conn_during_recovery="false"
        return
    fi

    # Check staleness (ping daemon may have crashed)
    local ping_ts now age
    ping_ts=$(grep '"timestamp"' "$PING_CACHE" 2>/dev/null | grep -o '[0-9]*')
    now=$(date +%s)

    if [ -n "$ping_ts" ]; then
        age=$((now - ping_ts))
        if [ "$age" -gt "$PING_STALE_THRESHOLD" ]; then
            qlog_warn "Ping data stale (age=${age}s), marking unknown"
            conn_internet_available="null"
            conn_status="unknown"
            conn_latency="null"
            conn_avg_latency="null"
            conn_min_latency="null"
            conn_max_latency="null"
            conn_jitter="null"
            conn_packet_loss=0
            conn_history="[]"
            conn_during_recovery="false"
            return
        fi
    fi

    # Extract fields from ping JSON using grep/awk (no jq on BusyBox)
    # Helper: extract a JSON value by key. Handles numbers, booleans, null, and strings.
    _pval() {
        local key="$1"
        grep "\"${key}\"" "$PING_CACHE" 2>/dev/null | \
            sed 's/.*: *//; s/,$//' | tr -d ' \r' | head -1
    }

    conn_internet_available=$(_pval "reachable")
    conn_latency=$(_pval "last_rtt_ms")
    conn_avg_latency=$(_pval "avg_rtt_ms")
    conn_min_latency=$(_pval "min_rtt_ms")
    conn_max_latency=$(_pval "max_rtt_ms")
    conn_jitter=$(_pval "jitter_ms")
    conn_packet_loss=$(_pval "packet_loss_pct")
    conn_during_recovery=$(_pval "during_recovery")
    conn_history_interval=$(_pval "interval_sec")

    # Extract first target from the targets array
    conn_ping_target=$(grep '"targets"' "$PING_CACHE" 2>/dev/null | \
        grep -o '"[0-9.]*"' | head -1 | tr -d '"')

    # Extract the history array (entire line from [ to ])
    conn_history=$(awk '/"history"/{found=1} found{line=line $0} /\]/{if(found){print line; exit}}' "$PING_CACHE" 2>/dev/null | \
        sed 's/.*"history": *//' | tr -d ' \r')
    [ -z "$conn_history" ] && conn_history="[]"

    # Derive connectivity status from ping data + modem state
    if [ "$conn_during_recovery" = "true" ]; then
        conn_status="recovery"
    elif [ "$conn_internet_available" = "true" ]; then
        local loss="${conn_packet_loss:-0}"
        if [ "$loss" -ge 10 ] 2>/dev/null; then
            conn_status="degraded"
        else
            conn_status="connected"
        fi
    elif [ "$conn_internet_available" = "false" ]; then
        conn_status="disconnected"
    else
        conn_status="unknown"
    fi

    # Sanitize: ensure numeric fields are valid
    case "$conn_packet_loss" in
        *[!0-9]*|'') conn_packet_loss=0 ;;
    esac
    case "$conn_history_interval" in
        *[!0-9]*|'') conn_history_interval=2 ;;
    esac
}

# =============================================================================
# JSON CACHE WRITER
# =============================================================================

write_cache() {
    local timestamp
    timestamp=$(date +%s)

    # Null-safe JSON values
    local json_lte_earfcn="${lte_earfcn:-null}"
    local json_lte_pci="${lte_pci:-null}"
    local json_lte_rsrp="${lte_rsrp:-null}"
    local json_lte_rsrq="${lte_rsrq:-null}"
    local json_lte_sinr="${lte_sinr:-null}"
    local json_lte_rssi="${lte_rssi:-null}"
    local json_lte_bandwidth="${lte_bandwidth:-null}"
    local json_lte_ta="${lte_ta:-null}"

    local json_nr_arfcn="${nr_arfcn:-null}"
    local json_nr_pci="${nr_pci:-null}"
    local json_nr_rsrp="${nr_rsrp:-null}"
    local json_nr_rsrq="${nr_rsrq:-null}"
    local json_nr_sinr="${nr_sinr:-null}"
    local json_nr_scs="${nr_scs:-null}"
    local json_nr_ta="${nr_ta:-null}"

    local json_temperature="${t2_temperature:-null}"

    local errors_json="[]"
    if [ -n "$errors" ]; then
        errors_json="[\"${errors}\"]"
    fi

    cat > "$CACHE_TMP" << JSONEOF
{
  "timestamp": ${timestamp},
  "system_state": "${system_state}",
  "modem_reachable": ${modem_reachable},
  "last_successful_poll": ${timestamp},
  "errors": ${errors_json},
  "network": {
    "type": "${network_type:-LTE}",
    "sim_slot": ${t2_sim_slot:-1},
    "carrier": "${t2_carrier}",
    "service_status": "${service_status}",
    "ca_active": ${t2_ca_active},
    "ca_count": ${t2_ca_count},
    "nr_ca_active": ${t2_nr_ca_active},
    "nr_ca_count": ${t2_nr_ca_count}
  },
  "lte": {
    "state": "${lte_state}",
    "band": "${lte_band}",
    "earfcn": ${json_lte_earfcn},
    "bandwidth": ${json_lte_bandwidth},
    "pci": ${json_lte_pci},
    "rsrp": ${json_lte_rsrp},
    "rsrq": ${json_lte_rsrq},
    "sinr": ${json_lte_sinr},
    "rssi": ${json_lte_rssi},
    "ta": ${json_lte_ta}
  },
  "nr": {
    "state": "${nr_state}",
    "band": "${nr_band}",
    "arfcn": ${json_nr_arfcn},
    "pci": ${json_nr_pci},
    "rsrp": ${json_nr_rsrp},
    "rsrq": ${json_nr_rsrq},
    "sinr": ${json_nr_sinr},
    "scs": ${json_nr_scs},
    "ta": ${json_nr_ta}
  },
  "signal_per_antenna": {
    "lte_rsrp": ${sig_lte_rsrp},
    "lte_rsrq": ${sig_lte_rsrq},
    "lte_sinr": ${sig_lte_sinr},
    "nr_rsrp": ${sig_nr_rsrp},
    "nr_rsrq": ${sig_nr_rsrq},
    "nr_sinr": ${sig_nr_sinr}
  },
  "device": {
    "temperature": ${json_temperature},
    "cpu_usage": ${cpu_usage:-0},
    "memory_used_mb": ${memory_used_mb:-0},
    "memory_total_mb": ${memory_total_mb:-0},
    "uptime_seconds": ${uptime_seconds:-0},
    "conn_uptime_seconds": ${conn_uptime_seconds:-0},
    "firmware": "${boot_firmware}",
    "build_date": "${boot_build_date}",
    "manufacturer": "${boot_manufacturer}",
    "imei": "${boot_imei}",
    "imsi": "${boot_imsi}",
    "iccid": "${boot_iccid}",
    "phone_number": "${boot_phone_number}",
    "lte_category": "${boot_lte_category}",
    "mimo": "${boot_mimo}"
  },
  "traffic": {
    "rx_bytes_per_sec": ${rx_bytes_per_sec:-0},
    "tx_bytes_per_sec": ${tx_bytes_per_sec:-0},
    "total_rx_bytes": ${total_rx_bytes:-0},
    "total_tx_bytes": ${total_tx_bytes:-0}
  },
  "connectivity": {
    "internet_available": ${conn_internet_available:-null},
    "status": "${conn_status}",
    "latency_ms": ${conn_latency:-null},
    "avg_latency_ms": ${conn_avg_latency:-null},
    "min_latency_ms": ${conn_min_latency:-null},
    "max_latency_ms": ${conn_max_latency:-null},
    "jitter_ms": ${conn_jitter:-null},
    "packet_loss_pct": ${conn_packet_loss:-0},
    "ping_target": "${conn_ping_target}",
    "latency_history": ${conn_history:-[]},
    "history_interval_sec": ${conn_history_interval:-2},
    "history_size": ${CONN_HISTORY_SIZE:-60},
    "during_recovery": ${conn_during_recovery:-false}
  }
}
JSONEOF

    mv "$CACHE_TMP" "$CACHE_FILE"
}

# =============================================================================
# POLL CYCLE
# =============================================================================

poll_cycle() {
    if [ -f "$LONG_FLAG" ]; then
        if [ "$system_state" != "scan_in_progress" ]; then
            qlog_state_change "system_state" "$system_state" "scan_in_progress"
        fi
        system_state="scan_in_progress"
        update_proc_metrics
        read_ping_data
        update_conn_uptime
        write_cache
        return
    fi

    errors=""
    system_state="normal"

    # Tier 1
    poll_serving_cell
    sleep "$SIP_DELAY"

    # Tier 1.5 (per-antenna signal history)
    if [ $((cycle_count % TIER1_5_EVERY)) -eq 0 ]; then
        poll_per_antenna_signal
        sleep "$SIP_DELAY"
    fi

    # Tier 2
    if [ $((cycle_count % TIER2_EVERY)) -eq 0 ]; then
        poll_tier2
    fi

    update_proc_metrics
    read_ping_data
    update_conn_uptime
    determine_service_status
    detect_events
    write_cache

    cycle_count=$((cycle_count + 1))
}

# =============================================================================
# MAIN
# =============================================================================

main() {
    qlog_info "========================================"
    qlog_info "QManager Poller starting"
    qlog_info "Config: interval=${POLL_INTERVAL}s tier2_every=${TIER2_EVERY} iface=${NETWORK_IFACE}"
    qlog_info "Log level: ${QLOG_LEVEL:-INFO}"
    qlog_info "========================================"

    collect_boot_data
    update_proc_metrics
    write_cache

    qlog_info "Boot data collected, entering poll loop"

    while true; do
        poll_cycle
        sleep "$POLL_INTERVAL"
    done
}

main "$@"
