#!/bin/sh
# =============================================================================
# qmanager_poller — QManager Background Poller Daemon
# =============================================================================
# Continuously gathers modem data and system metrics, writes to the
# JSON state cache at /tmp/qmanager_status.json.
#
# Strategy: "Sip, Don't Gulp"
#   - Acquire lock → run ONE AT command → release → sleep → repeat
#   - Leaves gaps for terminal/watchdog to access the modem
#
# Tiers:
#   Tier 1 (Hot):    Every cycle (~2s)  — AT+QENG="servingcell", /proc reads
#   Tier 1.5 (Signal): Every 5 cycles (10s) — AT+QRSRP, AT+QRSRQ, AT+QSINR
#   Tier 2 (Warm):   Every 15 cycles    — AT+QTEMP, AT+COPS?, AT+CPIN?, AT+QUIMSLOT?,
#                                         AT+QCAINFO, AT+QNWCFG="*_time_advance",
#                                         AT+QNWCFG="*_mimo_layers" (network-mode-gated),
#                                         AT+CGCONTRDP, AT+QMAP="WWAN"
#   Boot-only:     Once at startup    — AT+CVERSION, AT+CGSN, AT+CIMI, AT+QCCID,
#                                       AT+CNUM, AT+QGETCAPABILITY,
#                                       AT+QNWPREFCFG="policy_band"
#
# Libraries (sourced at startup):
#   /usr/lib/qmanager/qlog.sh      — Centralized logging
#   /usr/lib/qmanager/parse_at.sh  — AT command response parsers
#   /usr/lib/qmanager/events.sh    — Network event detection
#
# Install location: /usr/bin/qmanager_poller
# =============================================================================

# --- Configuration -----------------------------------------------------------
