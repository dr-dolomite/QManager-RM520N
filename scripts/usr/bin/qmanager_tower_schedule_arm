#!/bin/sh
# qmanager_tower_schedule_arm — Arm/disarm the Tower Lock schedule systemd
# timers live.
#
# RM520N has no crond (see schedule_timer.sh header). The Tower Lock schedule
# has TWO boundaries per day — an apply-time and a clear-time — which used to
# be two lines in /var/spool/cron/crontabs/root that nothing ever read. This
# is the privileged half of the replacement: it generates two independent
# weekly OnCalendar= triggers (apply, clear) from the saved start/end times +
# shared day mask, writes qmanager-tower-schedule-apply.timer AND
# qmanager-tower-schedule-clear.timer, and arms/disarms BOTH for the current
# boot in one invocation — mirroring qmanager_scenario_schedule_arm /
# qmanager_auto_update_arm, extended to a pair of units instead of one.
#
# Called via: sudo -n /usr/bin/qmanager_tower_schedule_arm install <start HH:MM> <end HH:MM> <days_csv>
#             sudo -n /usr/bin/qmanager_tower_schedule_arm teardown
#
# MECHANISM — deliberate: manual symlink into
# /lib/systemd/system/timers.target.wants/, NOT `systemctl enable`. See
# qmanager_scenario_schedule_arm's header for the full "systemctl enable puts
# state in /etc, everything else here lives in /lib" rationale — this helper
# mirrors it exactly, just for two units instead of one.
#
# Persistent=false on both timers — a missed apply/clear window during
# downtime must NOT stack-fire at boot (an apply firing hours late, or a
# clear firing right after an unrelated reboot, would surprise the user).
#
# Idempotent both directions. No-op (success) if EITHER target .service is
# absent — an OTA-upgraded device that predates this feature must not
# surface a hard error to the caller, and arming only half the pair would be
# a worse failure mode than arming neither.
#
# SECURITY: this is a sudo-reachable root helper. The CGI-side validation in
# tower/schedule.sh is necessary but NOT sufficient — this helper
# re-validates start time, end time, and the day-mask itself (charset-gate
# BEFORE shape-check, see schedule_timer.sh) before any value is
# interpolated into a generated .timer unit's OnCalendar= line. Never eval'd.

PATH=/opt/bin:/opt/sbin:/usr/bin:/usr/sbin:/bin:/sbin
export PATH

UNIT_DIR="/lib/systemd/system"
WANTS_DIR="/lib/systemd/system/timers.target.wants"

UNIT_APPLY="qmanager-tower-schedule-apply.timer"
SERVICE_APPLY="qmanager-tower-schedule-apply.service"
UNIT_CLEAR="qmanager-tower-schedule-clear.timer"
SERVICE_CLEAR="qmanager-tower-schedule-clear.service"

action="$1"
start_time="$2"
end_time="$3"
days="$4"

# Strict arg validation — only the two verbs, nothing else.
case "$action" in
    install|teardown) ;;
    *) printf '{"success":false,"error":"invalid_action","detail":"action must be install or teardown"}\n'; exit 1 ;;
esac

teardown_all() {
    for u in "$UNIT_APPLY" "$UNIT_CLEAR"; do
        systemctl stop "$u" 2>/dev/null || true
        rm -f "$WANTS_DIR/$u" 2>/dev/null
        rm -f "$UNIT_DIR/$u" 2>/dev/null
    done
    systemctl daemon-reload 2>/dev/null || true
}

# Missing-unit no-op: if EITHER half of the pair is absent (older OTA base
# predates this feature), there is nothing to schedule against. Report
# success so the caller still lands cleanly instead of surfacing a hard
# error, and never arm just one side of the pair.
if [ ! -f "$UNIT_DIR/$SERVICE_APPLY" ] || [ ! -f "$UNIT_DIR/$SERVICE_CLEAR" ]; then
    printf '{"success":true,"armed":false,"reason":"unit_absent"}\n'
    exit 0
fi

if [ "$action" = "teardown" ]; then
    teardown_all
    printf '{"success":true,"armed":false,"reason":""}\n'
    exit 0
fi

# --- install --------------------------------------------------------------
if [ ! -f /usr/lib/qmanager/schedule_timer.sh ]; then
    printf '{"success":false,"error":"lib_missing","detail":"schedule_timer.sh not found"}\n'
    exit 1
fi
. /usr/lib/qmanager/schedule_timer.sh

if ! _qm_validate_hhmm "$start_time"; then
    printf '{"success":false,"error":"invalid_start_time","detail":"start_time must be HH:MM"}\n'
    exit 1
fi
if ! _qm_validate_hhmm "$end_time"; then
    printf '{"success":false,"error":"invalid_end_time","detail":"end_time must be HH:MM"}\n'
    exit 1
fi
if ! _qm_validate_days "$days"; then
    printf '{"success":false,"error":"invalid_days","detail":"days must be a comma list of 0-6"}\n'
    exit 1
fi

apply_line=$(_qm_oncalendar_line "$days" "$start_time")
clear_line=$(_qm_oncalendar_line "$days" "$end_time")

# No resolvable day -> tear down any existing timers rather than arm a
# .timer pair with a zero OnCalendar= line (a systemd config error).
if [ -z "$apply_line" ] || [ -z "$clear_line" ]; then
    teardown_all
    printf '{"success":true,"armed":false,"reason":"no_schedule"}\n'
    exit 0
fi

# /lib lives on read-only-by-default UBIFS; ensure writable. Idempotent — a
# no-op if already rw. Left rw afterwards, matching the reference helpers.
mount -o remount,rw / 2>/dev/null || true

# write_timer <unit> <service> <description> <oncalendar-line>
# Atomic write: build the unit in a tmp file, then mv over the target — a
# concurrent systemd daemon-reload must never observe a half-written unit.
write_timer() {
    _unit="$1"; _service="$2"; _desc="$3"; _line="$4"
    _tmp="${UNIT_DIR}/.${_unit}.tmp.$$"
    {
        printf '[Unit]\n'
        printf 'Description=%s\n' "$_desc"
        printf '\n[Timer]\n'
        printf '%s\n' "$_line"
        printf 'Unit=%s\n' "$_service"
        printf 'Persistent=false\n'
        printf '\n[Install]\n'
        printf 'WantedBy=timers.target\n'
    } > "$_tmp" 2>/dev/null
    if [ ! -s "$_tmp" ]; then
        rm -f "$_tmp" 2>/dev/null
        return 1
    fi
    mv "$_tmp" "$UNIT_DIR/$_unit" || return 1
    mkdir -p "$WANTS_DIR" 2>/dev/null || return 1
    ln -sf "$UNIT_DIR/$_unit" "$WANTS_DIR/$_unit" 2>/dev/null || return 1
    return 0
}

rc=0
write_timer "$UNIT_APPLY" "$SERVICE_APPLY" "QManager tower lock schedule (apply)" "$apply_line" || rc=1
write_timer "$UNIT_CLEAR" "$SERVICE_CLEAR" "QManager tower lock schedule (clear)" "$clear_line" || rc=1

sync
systemctl daemon-reload 2>/dev/null || true
systemctl start "$UNIT_APPLY" 2>/dev/null || true   # arm the TIMERS for this boot too, not the services
systemctl start "$UNIT_CLEAR" 2>/dev/null || true

if [ "$rc" -ne 0 ] || [ ! -L "$WANTS_DIR/$UNIT_APPLY" ] || [ ! -L "$WANTS_DIR/$UNIT_CLEAR" ]; then
    # Best-effort: don't leave a half-armed pair behind on failure.
    teardown_all
    printf '{"success":false,"error":"arm_failed","detail":"could not create timer symlink"}\n'
    exit 1
fi

printf '{"success":true,"armed":true,"reason":""}\n'
exit 0
