#!/bin/sh
# =============================================================================
# qcmd — QManager Gatekeeper (RM520N-GL Variant)
# =============================================================================
# The SINGLE entry point for ALL modem communication on the RM520N-GL.
# Uses flock to serialize access to the modem's AT channel via socat PTY bridge.
#
# This is the RM520N-GL variant of qcmd. It uses sms_tool targeting the
# socat-at-bridge PTY device (/dev/ttyOUT2 for smd7). The interface contract
# is identical to the RM551E variant — all callers work without modification.
#
# Why ttyOUT2 (smd7) and not ttyOUT (smd11):
#   - sms_tool works reliably on ttyOUT2 but has timing issues on ttyOUT
#   - smd7 requires killsmd7bridge to have run at boot (standard with RGMII toolkit)
#   - ttyOUT (smd11) can still be used via microcom for other purposes
#
# Usage:
#   qcmd "AT+COMMAND"          → Execute AT command, return raw result
#   qcmd -j "AT+COMMAND"       → Execute AT command, return JSON-wrapped result
#
# Install location: /usr/bin/qcmd
# Dependencies: sms_tool (static ARM binary), flock, timeout, jq (for -j mode)
# Prerequisite: socat-at-bridge must be running (provides /dev/ttyOUT2)
# =============================================================================

# --- Logging -----------------------------------------------------------------
if [ -f /usr/lib/qmanager/qlog.sh ]; then
    . /usr/lib/qmanager/qlog.sh
else
    qlog_init() { :; }
    qlog_debug() { :; }
    qlog_info() { :; }
    qlog_warn() { :; }
    qlog_error() { :; }
    qlog_at_cmd() { :; }
    qlog_lock() { :; }
fi
qlog_init "qcmd"

# --- Configuration -----------------------------------------------------------
LOCK_FILE="/tmp/qmanager_at.lock"
LONG_FLAG="/tmp/qmanager_long_running"
PID_FILE="/tmp/qmanager_at.pid"

SHORT_TIMEOUT=3        # seconds for normal AT commands
LONG_TIMEOUT=240       # seconds for AT+QSCAN and similar
LONG_SAFETY_TIMEOUT=260 # outer timeout safety net (20s beyond LONG_TIMEOUT)
LOCK_WAIT_SHORT=5      # seconds to wait for lock (normal commands)
LOCK_WAIT_LONG=10      # seconds to wait for lock (long commands)

# Ensure lock/pid files exist and are accessible by both root and www-data.
# The poller (root) and CGI scripts (www-data) share these files via flock.
[ ! -f "$LOCK_FILE" ] && touch "$LOCK_FILE" 2>/dev/null
[ ! -f "$PID_FILE" ] && touch "$PID_FILE" 2>/dev/null
chmod 666 "$LOCK_FILE" "$PID_FILE" 2>/dev/null

# --- AT device configuration (RM520N-GL: socat PTY bridge) -------------------
# Default: /dev/ttyOUT2 (smd7 via socat bridge, requires killsmd7bridge at boot)
# Override: write device path to /etc/qmanager/at_device (e.g. /dev/ttyOUT)
_DEFAULT_DEV="/dev/ttyOUT2"
_sms_dev="$_DEFAULT_DEV"
if [ -f /etc/qmanager/at_device ]; then
    _dev=$(cat /etc/qmanager/at_device 2>/dev/null)
    [ -n "$_dev" ] && _sms_dev="$_dev"
fi
SMS_TOOL_ARGS="-d $_sms_dev"

# Verify AT device exists (socat-at-bridge must be running)
if [ ! -e "$_sms_dev" ]; then
    echo "ERROR: AT device $_sms_dev not found. Is socat-at-bridge running?" >&2
    exit 1
fi

# --- Parse Arguments ---------------------------------------------------------
JSON_MODE=0
if [ "$1" = "-j" ]; then
    JSON_MODE=1
    shift
fi

COMMAND="$1"

if [ -z "$COMMAND" ]; then
    qlog_error "No command provided"
    echo '{"error":"no_command","detail":"Usage: qcmd [-j] \"AT+COMMAND\""}' >&2
    exit 1
fi

qlog_debug "Command received: ${COMMAND}"

# --- Helper: JSON Output -----------------------------------------------------
output_result() {
    local raw="$1"
    local err="$2"

    if [ "$JSON_MODE" -eq 1 ]; then
        if [ -n "$err" ]; then
            jq -n --arg error "$err" --arg command "$COMMAND" \
                '{success: false, error: $error, command: $command}'
        else
            jq -n --arg response "$raw" --arg command "$COMMAND" \
                '{success: true, response: $response, command: $command}'
        fi
    else
        if [ -n "$err" ]; then
            echo "ERROR: $err" >&2
            exit 1
        else
            echo "$raw"
        fi
    fi
}

# --- Helper: Command Classification -----------------------------------------
is_long_command() {
    local cmd="$1"

    if [ -f /etc/qmanager/long_commands.list ]; then
        while IFS= read -r pattern; do
            case "$pattern" in
                '#'*|'') continue ;;
            esac
            case "$cmd" in
                *"$pattern"*) return 0 ;;
            esac
        done < /etc/qmanager/long_commands.list
    fi

    case "$cmd" in
        *QSCAN*|*QSCANFREQ*|*QFOTADL*) return 0 ;;
        *) return 1 ;;
    esac
}

# --- Helper: Stale Lock Recovery ---------------------------------------------
check_stale_lock() {
    if [ -f "$PID_FILE" ]; then
        local old_pid
        old_pid=$(cat "$PID_FILE" 2>/dev/null)
        if [ -n "$old_pid" ] && ! kill -0 "$old_pid" 2>/dev/null; then
            qlog_lock "stale_recovery" "$old_pid"
            rm -f "$PID_FILE"
            return 0
        fi
    fi
    return 1
}

# --- Helper: flock with timeout ----------------------------------------------
# Usage: flock_wait <fd> <timeout_seconds>
# Returns: 0 = lock acquired, 1 = timed out
# -----------------------------------------------------------------------------
flock_wait() {
    local fd="$1"
    local wait_secs="$2"
    local elapsed=0

    while [ "$elapsed" -lt "$wait_secs" ]; do
        if flock -x -n "$fd" 2>/dev/null; then
            return 0
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done

    # One final try
    flock -x -n "$fd" 2>/dev/null
    return $?
}

# --- Helper: Long AT Command via Direct Device I/O --------------------------
# sms_tool has a hardcoded ~5s read timeout which is too short for commands
# like AT+QSCAN (up to 180s). This function bypasses sms_tool and uses direct
# PTY I/O with a background reader — same pattern as SimpleAdmin's atcmd helper.
#
# Usage: _run_long_at <command> <timeout_seconds> <device>
# Returns: 0 = OK received, 1 = ERROR received, 4 = timeout (no OK/ERROR)
# Stdout: raw modem response
# -----------------------------------------------------------------------------
_run_long_at() {
    local cmd="$1"
    local max_secs="$2"
    local dev="$3"
    local tmpfile="/tmp/qmanager_long_at_$$.tmp"

    rm -f "$tmpfile"
    : > "$tmpfile"

    # Send command to modem via PTY
    printf '%s\r' "$cmd" > "$dev"

    # Background reader — captures all modem output to temp file
    cat "$dev" > "$tmpfile" 2>/dev/null &
    local reader_pid=$!

    # Poll for OK/ERROR with wall-clock timeout
    local elapsed=0
    while [ "$elapsed" -lt "$max_secs" ]; do
        sleep 1
        elapsed=$((elapsed + 1))
        if grep -qe 'OK' -e 'ERROR' "$tmpfile" 2>/dev/null; then
            # Brief pause to capture any trailing output after OK
            sleep 0.5
            break
        fi
    done

    # Stop the reader
    kill "$reader_pid" 2>/dev/null
    wait "$reader_pid" 2>/dev/null

    # Read results and determine exit code
    local output=""
    [ -s "$tmpfile" ] && output=$(cat "$tmpfile")
    rm -f "$tmpfile"

    printf '%s' "$output"

    case "$output" in
        *OK*)    return 0 ;;
        *ERROR*) return 1 ;;
        *)       return 4 ;;  # Timeout — no OK or ERROR received
    esac
}

# =============================================================================
# EXECUTION
#
# Uses subshell + FD 9 redirect: ( flock 9; ...; ) 9<"$LOCK_FILE"
# Lock is auto-released when the subshell exits.
# =============================================================================

if is_long_command "$COMMAND"; then
    # =========================================================================
    # LONG COMMAND PATH
    # =========================================================================
    qlog_info "Long command started: ${COMMAND}"
    echo "$COMMAND" > "$LONG_FLAG"

    result=$(
        (
            if ! flock_wait 9 "$LOCK_WAIT_LONG"; then
                exit 2
            fi
            echo $$ > "$PID_FILE"

            # Warm-up: flush residual serial buffer data + confirm modem responsive
            sms_tool $SMS_TOOL_ARGS at "AT" > /dev/null 2>&1 || { rm -f "$PID_FILE"; exit 3; }

            # Real command via direct device I/O (sms_tool's 5s timeout is too
            # short for long commands like AT+QSCAN which take up to 180s)
            _run_long_at "$COMMAND" "$LONG_TIMEOUT" "$_sms_dev"
            cmd_rc=$?
            rm -f "$PID_FILE"
            exit $cmd_rc
        ) 9<"$LOCK_FILE"
    )
    exit_code=$?

    rm -f "$LONG_FLAG"

    case $exit_code in
        0)
            qlog_info "Long command completed: ${COMMAND}"
            qlog_at_cmd "$COMMAND" "$result" "$exit_code"
            output_result "$result" ""
            ;;
        1)
            qlog_error "Long command returned ERROR: ${COMMAND}"
            qlog_at_cmd "$COMMAND" "$result" "$exit_code"
            output_result "" "command_failed"
            exit 1
            ;;
        2)
            qlog_error "Lock acquisition failed for: ${COMMAND}"
            output_result "" "modem_busy"
            exit 1
            ;;
        3)
            qlog_error "Modem warm-up failed before: ${COMMAND}"
            output_result "" "modem_not_ready"
            exit 1
            ;;
        4)
            qlog_error "Long command timed out (no OK/ERROR in ${LONG_TIMEOUT}s): ${COMMAND}"
            output_result "" "command_timeout"
            exit 1
            ;;
        *)
            qlog_error "Long command failed: ${COMMAND} (exit=${exit_code})"
            output_result "" "command_failed"
            exit 1
            ;;
    esac

elif [ -f "$LONG_FLAG" ]; then
    # =========================================================================
    # LONG COMMAND IN PROGRESS — Reject immediately
    # =========================================================================
    qlog_lock "blocked" "$(cat "$LONG_FLAG" 2>/dev/null)"
    output_result "" "scan_in_progress"
    exit 1

else
    # =========================================================================
    # SHORT COMMAND PATH
    # =========================================================================
    result=$(
        (
            if ! flock_wait 9 "$LOCK_WAIT_SHORT"; then
                exit 2
            fi
            echo $$ > "$PID_FILE"
            timeout "$SHORT_TIMEOUT" sms_tool $SMS_TOOL_ARGS at "$COMMAND" 2>/dev/null
            cmd_rc=$?
            rm -f "$PID_FILE"
            exit $cmd_rc
        ) 9<"$LOCK_FILE"
    )
    exit_code=$?

    # Lock failed — try stale recovery and retry once
    if [ $exit_code -eq 2 ]; then
        qlog_lock "timeout" "short command: ${COMMAND}"

        if check_stale_lock; then
            result=$(
                (
                    if ! flock_wait 9 2; then
                        exit 2
                    fi
                    echo $$ > "$PID_FILE"
                    timeout "$SHORT_TIMEOUT" sms_tool $SMS_TOOL_ARGS at "$COMMAND" 2>/dev/null
                    cmd_rc=$?
                    rm -f "$PID_FILE"
                    exit $cmd_rc
                ) 9<"$LOCK_FILE"
            )
            exit_code=$?
        fi

        if [ $exit_code -eq 2 ]; then
            qlog_error "Lock acquisition failed for: ${COMMAND}"
            output_result "" "modem_busy"
            exit 1
        fi
    fi

    qlog_at_cmd "$COMMAND" "$result" "$exit_code"

    if [ $exit_code -ne 0 ]; then
        qlog_error "Short command timeout: ${COMMAND} (exit=${exit_code})"
        output_result "" "command_timeout"
        exit 1
    fi

    output_result "$result" ""
fi
