#!/bin/sh
# =============================================================================
# qmanager_update — Background OTA updater
# =============================================================================
# Spawned by update.sh CGI. Downloads, verifies, installs, and reboots.
#
# Usage:
#   qmanager_update install <download_url> <version> [download_size] [--unattended]
#   qmanager_update download <tarball_url> <checksum_url> <version>
#   qmanager_update install_staged
#   qmanager_update rollback <rollback_url> <rollback_version>
#
# The optional [--unattended] (alias --strict) flag on "install" is set by
# qmanager_auto_update: it makes SHA-256 verification mandatory rather than
# best-effort, since nobody is watching the progress UI to catch a bad
# unattended install before it reboots the device. See verify_checksum().
# =============================================================================

LOG_FILE="/tmp/qmanager_update.log"
INSTALL_LOG="/tmp/qmanager_install.log"
STATUS_FILE="/tmp/qmanager_update.json"
PID_FILE="/tmp/qmanager_update.pid"
REBOOT_ACK_FILE="/tmp/qmanager_reboot_ack"
WATCHCAT_LOCK="/tmp/qmanager_watchcat.lock"
# 20s gives the cold-cache /reboot/ page time to download bundles, hydrate,
# and fire reboot_ack before the worker proceeds. Matches the CGI default in
# cgi_base.sh ($QM_REBOOT_ACK_TIMEOUT) so every reboot path shares one budget.
REBOOT_ACK_TIMEOUT=20
VERSION_FILE="/etc/qmanager/VERSION"
PENDING_FILE="/etc/qmanager/VERSION.pending"
UPDATES_DIR="/etc/qmanager/updates"

# Platform abstraction (systemd support)
[ -f /usr/lib/qmanager/platform.sh ] && . /usr/lib/qmanager/platform.sh

# Forward-compat: load shared semver helpers if available
[ -f /usr/lib/qmanager/semver.sh ] && . /usr/lib/qmanager/semver.sh

# Downloader abstraction (curl/wget auto-detect). The inline fallback keeps OTA
# working if the library is somehow absent (e.g. a partial install).
if [ -f /usr/lib/qmanager/downloader.sh ]; then
    . /usr/lib/qmanager/downloader.sh
else
    export PATH="/opt/bin:/opt/sbin:/usr/bin:/usr/sbin:/bin:/sbin:$PATH"
    qm_download() {
        local url="$1" dest="$2" timeout="${3:-120}" rc
        if command -v curl >/dev/null 2>&1; then
            curl -fSL --max-time "$timeout" -o "$dest" "$url"
        elif command -v wget >/dev/null 2>&1; then
            wget -q -T "$timeout" -O "$dest" "$url"
        else
            return 1
        fi
        rc=$?
        [ "$rc" -ne 0 ] && rm -f "$dest"
        return "$rc"
    }
fi

# --- Helpers -----------------------------------------------------------------

log() { printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$1" >> "$LOG_FILE"; }

# Atomic write — prevents readers from seeing partial JSON during the write
write_status() {
    local status="$1" msg="$2" version="$3" size="$4"
    jq -n \
        --arg status "$status" \
        --arg message "$msg" \
        --arg version "$version" \
        --arg size "$size" \
        '{status: $status, message: $message, version: $version, size: $size}' \
        > "${STATUS_FILE}.tmp" && mv "${STATUS_FILE}.tmp" "$STATUS_FILE"
}

get_current_version() {
    if [ -f "$VERSION_FILE" ]; then
        tr -d '[:space:]' < "$VERSION_FILE"
    else
        echo "0.0.0"
    fi
}

http_download() {
    local url="$1" dest="$2" timeout="${3:-120}"
    # Transport is curl or wget, whichever the device has (see downloader.sh).
    if ! qm_download "$url" "$dest" "$timeout"; then
        log "ERROR: download failed for $url (no curl/wget, or network error)"
        return 1
    fi
    return 0
}

# Validate a tarball URL against the GitHub origin whitelist.
# Mode "strict" (2nd arg = "strict") allows only the releases path;
# default allows both releases and raw/qmanager-build paths (install mode).
validate_url() {
    local url="$1" strict="${2:-}"
    case "$url" in
        https://github.com/dr-dolomite/QManager-RM520N/releases/download/*/qmanager.tar.gz)
            return 0
            ;;
        https://github.com/dr-dolomite/QManager-RM520N/raw/*/qmanager-build/qmanager.tar.gz)
            # raw/qmanager-build path is only permitted for the one-step install mode
            if [ "$strict" = "strict" ]; then
                return 1
            fi
            return 0
            ;;
    esac
    return 1
}

# Verify that a tarball is readable and contains the expected installer entry.
verify_archive() {
    local path="$1"
    tar tzf "$path" >/dev/null 2>&1 || return 1
    tar tzf "$path" 2>/dev/null | grep -q "install_rm520n.sh" || return 1
    return 0
}

# A GitHub Release publishes qmanager.tar.gz and sha256sum.txt as siblings in
# the same release. "install" mode is only ever given the tarball URL (unlike
# "download" mode, which receives an explicit checksum URL from the CGI) — so
# for the releases path we derive the sibling checksum URL ourselves. The
# raw/qmanager-build path (dev/one-step installs) has no such sibling and
# yields an empty string, which verify_checksum() treats as "unavailable".
derive_checksum_url() {
    local tarball_url="$1"
    case "$tarball_url" in
        https://github.com/dr-dolomite/QManager-RM520N/releases/download/*/qmanager.tar.gz)
            printf '%s' "${tarball_url%/qmanager.tar.gz}/sha256sum.txt"
            ;;
        *)
            printf ''
            ;;
    esac
}

# Fetch + verify a tarball's SHA-256 against a checksum URL. Shared by both
# "download" (staged) and "install" (one-step) modes so the two paths carry
# identical integrity guarantees — previously only "download" mode verified
# checksums at all.
#
# Return codes:
#   0 = verified OK, or skipped and the caller's strictness allows that
#   1 = checksum unavailable/unverifiable AND strict — caller must die
#   2 = checksum present but MISMATCHED — always fatal regardless of strict;
#       a mismatch is a corruption/tamper signal, never a "just proceed" gap
#
# strict="strict" is set by qmanager_auto_update (the unattended, reboot-
# capable path) — it must never install unverified bytes. The manual/UI path
# passes strict="" so a human watching the progress UI can still proceed past
# a transient checksum-hosting hiccup, same as today. Every skip/verify/
# mismatch outcome is always logged — silence was the actual bug being fixed.
verify_checksum() {
    local tarball="$1" checksum_url="$2" strict="$3"
    local checksum_file="/tmp/qmanager_update_sha256.txt"
    local expected_sha="" actual_sha=""

    if [ -z "$checksum_url" ]; then
        log "SHA-256 check skipped — no checksum URL available for this install"
        [ "$strict" = "strict" ] && return 1
        return 0
    fi

    rm -f "$checksum_file"
    if ! http_download "$checksum_url" "$checksum_file" 15; then
        log "SHA-256 check skipped — checksum file not available at $checksum_url"
        rm -f "$checksum_file"
        [ "$strict" = "strict" ] && return 1
        return 0
    fi

    if ! command -v sha256sum >/dev/null 2>&1; then
        log "SHA-256 check skipped — sha256sum not available on this system"
        rm -f "$checksum_file"
        [ "$strict" = "strict" ] && return 1
        return 0
    fi

    expected_sha=$(awk '{print $1}' "$checksum_file" 2>/dev/null)
    actual_sha=$(sha256sum "$tarball" 2>/dev/null | awk '{print $1}')
    rm -f "$checksum_file"

    if [ -z "$expected_sha" ] || [ -z "$actual_sha" ]; then
        log "SHA-256 check skipped — could not parse checksum value(s) from $checksum_url"
        [ "$strict" = "strict" ] && return 1
        return 0
    fi

    if [ "$actual_sha" != "$expected_sha" ]; then
        log "SHA-256 MISMATCH (expected $expected_sha, got $actual_sha)"
        return 2
    fi

    log "SHA-256 verified ($actual_sha)"
    return 0
}

# Run install_rm520n.sh with step-streaming progress updates to the UI.
# Installer stdout/stderr go to INSTALL_LOG (separate from the worker LOG_FILE)
# so we can poll it cleanly; the install log is appended to LOG_FILE on exit.
# Returns the installer's exit code.
run_install_with_progress() {
    local version="$1"
    local last_label="" current_label="" step_line="" rc=0

    : > "$INSTALL_LOG"
    # --force skips the firmware-detection prompt; OTA only ever targets an
    # already-running QManager device, and the installer's stdin is closed in
    # this CGI-spawned context (read would EOF and abort under set -e).
    sh install_rm520n.sh --force --skip-packages --no-reboot >> "$INSTALL_LOG" 2>&1 &
    local install_pid=$!

    while pid_alive "$install_pid"; do
        sleep 2

        # Installer's _log_raw() emits "[timestamp] === Step N/M: <label> ===" —
        # this is the documented tail-target contract. Plain ASCII, no ANSI noise.
        step_line=$(grep '=== Step ' "$INSTALL_LOG" 2>/dev/null | tail -1)
        if [ -n "$step_line" ]; then
            current_label=$(printf '%s' "$step_line" \
                | sed -n 's/.*=== Step [0-9]*\/[0-9]*: \(.*\) ===.*/\1/p')
        fi

        if [ -n "$current_label" ] && [ "$current_label" != "$last_label" ]; then
            write_status "installing" "$current_label" "$version" ""
            log "Install step: $current_label"
            last_label="$current_label"
        fi
    done

    wait "$install_pid"
    rc=$?

    # Merge install output into the main worker log for a single audit trail
    cat "$INSTALL_LOG" >> "$LOG_FILE" 2>/dev/null
    rm -f "$INSTALL_LOG"

    return $rc
}

# Verify the installed VERSION matches what was expected.
# A VERSION.pending file means the installer died mid-flight.
#
# The comparison is semantic, not byte-exact. install_rm520n.sh stamps
# VERSION with whatever build.sh baked in from package.json at build time —
# which can carry a pre-release suffix (e.g. "v0.1.13-draft") even when the
# GitHub release itself was tagged clean ("v0.1.13"). A byte-exact compare
# would then report a fully successful OTA as a fatal failure. Rule:
#   - major.minor.patch CORE differs               -> fatal (die)
#   - only a "v" prefix / "-suffix" difference      -> warn, treat as success
# We extract cores with plain shell parameter expansion (matching semver.sh's
# own "${v#v}" / "${v%%-*}" idiom) rather than adding a new helper to
# semver.sh, since semver_compare()'s ordering semantics (no-prerelease always
# "newer" than any prerelease) can't disambiguate a genuine numeric mismatch
# from a same-core prerelease-only difference — both can return exit code 2.
post_install_check() {
    local expected="$1" actual=""

    if [ -f "$PENDING_FILE" ]; then
        die "Install appears to have crashed mid-flight (VERSION.pending exists). Check $LOG_FILE."
    fi

    if [ -f "$VERSION_FILE" ]; then
        actual=$(tr -d '[:space:]' < "$VERSION_FILE")
    fi

    if [ -z "$actual" ]; then
        die "Install completed but VERSION not stamped (expected $expected, got <missing>). Check $LOG_FILE."
    fi

    if [ "$actual" = "$expected" ]; then
        return 0
    fi

    local expected_core actual_core
    expected_core="${expected#v}"; expected_core="${expected_core%%-*}"
    actual_core="${actual#v}"; actual_core="${actual_core%%-*}"

    if [ "$expected_core" != "$actual_core" ]; then
        die "Install completed but VERSION mismatch (expected $expected, got $actual). Check $LOG_FILE."
    fi

    log "WARNING: VERSION differs only by a 'v' prefix / pre-release suffix (expected '$expected', got '$actual') — numeric core '$actual_core' matches, treating install as success."
}

cleanup() {
    rm -f "$PID_FILE"
    rm -rf /tmp/qmanager_install
    rm -f "$WATCHCAT_LOCK"
}

# Wait for the /reboot/ page to confirm it has loaded by writing
# REBOOT_ACK_FILE (via update.sh action=reboot_ack), then proceed with the
# reboot syscall. Bounded by REBOOT_ACK_TIMEOUT so a closed tab, auto-update,
# or any other UI-less invocation never blocks the reboot indefinitely.
wait_for_reboot_ack() {
    rm -f "$REBOOT_ACK_FILE" 2>/dev/null
    log "Waiting up to ${REBOOT_ACK_TIMEOUT}s for /reboot/ ack..."
    local i=0
    while [ $i -lt "$REBOOT_ACK_TIMEOUT" ]; do
        if [ -f "$REBOOT_ACK_FILE" ]; then
            log "Reboot ack received after ${i}s — UI confirmed /reboot/ loaded"
            rm -f "$REBOOT_ACK_FILE" 2>/dev/null
            return 0
        fi
        sleep 1
        i=$((i + 1))
    done
    log "Reboot ack timeout (${REBOOT_ACK_TIMEOUT}s) — proceeding without UI confirmation"
    return 0
}

die() {
    log "ERROR: $1"
    write_status "error" "$1" "${VERSION:-}" ""
    cleanup
    exit 1
}

# --- Lock & setup ------------------------------------------------------------

# fs.protected_regular=1 prevents root from truncating files owned by other
# users in sticky /tmp dirs. Prior failed CGI attempts may have left these
# files owned by www-data, so rm-then-create instead of plain truncate.
rm -f "$LOG_FILE" "$PID_FILE" "$REBOOT_ACK_FILE" 2>/dev/null || true
echo $$ > "$PID_FILE"
trap cleanup EXIT INT TERM
: > "$LOG_FILE"

MODE="$1"
log "Starting qmanager_update mode=$MODE"

# Stop watchdog early to prevent interference during download/install.
# Touch the same maintenance lock the daemon's check_locked() honors, so any
# watchcat instance still finishing a cycle parks in LOCKED instead of racing
# the OTA's AT commands; cleanup() removes it on exit.
# svc_stop translates underscores to dashes, so this maps to qmanager-watchcat.service
touch "$WATCHCAT_LOCK"
svc_stop qmanager_watchcat
log "Watchdog stopped"

# =============================================================================
# INSTALL mode — download, verify, install, reboot in one step
# =============================================================================
if [ "$MODE" = "install" ]; then
    URL="$2"
    VERSION="$3"
    SIZE="$4"
    # Strictness flag — set by qmanager_auto_update for the unattended path.
    # "" (manual/UI-triggered) warns and proceeds on an unverifiable checksum;
    # "--unattended"/"--strict" hard-fails instead, since nothing is watching
    # the progress UI to catch a bad install before it reboots the device.
    STRICT=""
    case "$5" in
        --unattended|--strict) STRICT="strict" ;;
    esac

    if ! validate_url "$URL"; then
        die "Invalid download URL"
    fi

    # 1. Download
    write_status "downloading" "Downloading update..." "$VERSION" "$SIZE"
    log "Downloading $URL"
    download_path="/tmp/qmanager_update_new.tar.gz"
    rm -f "$download_path"

    if ! http_download "$URL" "$download_path"; then
        die "Download failed. Check your internet connection."
    fi
    log "Download complete"

    # 2. Verify archive integrity
    write_status "verifying" "Verifying archive..." "$VERSION" ""
    if ! verify_archive "$download_path"; then
        rm -f "$download_path"
        die "Downloaded file is corrupt or missing install_rm520n.sh."
    fi
    log "Archive verified"

    # 2b. Verify SHA-256 — same integrity guarantee "download" mode already
    # has (see verify_checksum()). Previously "install" mode skipped this
    # entirely, so the unattended auto-update path installed unverified bytes.
    write_status "verifying" "Verifying SHA-256..." "$VERSION" ""
    checksum_url=$(derive_checksum_url "$URL")
    verify_checksum "$download_path" "$checksum_url" "$STRICT"
    checksum_rc=$?
    if [ "$checksum_rc" -eq 2 ]; then
        rm -f "$download_path"
        die "SHA-256 mismatch — download may be corrupt or tampered"
    elif [ "$checksum_rc" -eq 1 ]; then
        rm -f "$download_path"
        die "SHA-256 verification unavailable for an unattended install — refusing to install unverified update"
    fi

    # 3. Save current version for rollback tracking
    write_status "installing" "Installing update..." "$VERSION" ""
    current_ver=$(get_current_version)
    mkdir -p "$UPDATES_DIR"
    echo "$current_ver" > "$UPDATES_DIR/previous_version"
    log "Saved previous version ($current_ver) for rollback"

    # 4. Extract and run installer with step-streaming progress
    rm -rf /tmp/qmanager_install
    tar xzf "$download_path" -C /tmp/
    rm -f "$download_path"
    cd /tmp/qmanager_install || die "Extraction failed — /tmp/qmanager_install not found"

    log "Running install_rm520n.sh --force --skip-packages --no-reboot"
    if ! run_install_with_progress "$VERSION"; then
        die "Installation failed. Check $LOG_FILE for details."
    fi
    log "Install complete"

    # 5. Verify the VERSION file was stamped correctly
    post_install_check "$VERSION"

    # 6. Cleanup and reboot
    rm -rf /tmp/qmanager_install
    write_status "rebooting" "Rebooting device..." "$VERSION" ""
    log "Rebooting"
    rm -f "$PID_FILE"
    trap - EXIT INT TERM
    wait_for_reboot_ack
    reboot
    exit 0
fi

# =============================================================================
# DOWNLOAD mode — download and verify only, no install
# =============================================================================
if [ "$MODE" = "download" ]; then
    URL="$2"
    CHECKSUM_URL="$3"
    VERSION="$4"

    STAGED_TARBALL="/tmp/qmanager_staged.tar.gz"
    STAGED_VERSION="/tmp/qmanager_staged_version"

    # Strict validation — only releases path is accepted for staged downloads
    if ! validate_url "$URL" "strict"; then
        die "Invalid download URL"
    fi

    # 1. Download tarball
    write_status "downloading" "Downloading QManager ${VERSION}..." "$VERSION" ""
    log "Downloading $URL"
    rm -f "$STAGED_TARBALL"

    if ! http_download "$URL" "$STAGED_TARBALL"; then
        die "Download failed. Check your internet connection."
    fi
    log "Download complete"

    # 2. Verify archive integrity
    if ! verify_archive "$STAGED_TARBALL"; then
        rm -f "$STAGED_TARBALL"
        die "Downloaded file is corrupt or missing install_rm520n.sh."
    fi
    log "Archive integrity verified"

    # 3. SHA-256 verification — shared helper (see verify_checksum()). The
    # staged "download" flow is always human-triggered from the UI (auto-
    # update uses "install" mode, not "download"), so strict="" here: a
    # missing/unverifiable checksum warns and proceeds, matching prior
    # behavior. A mismatch is always fatal regardless.
    write_status "verifying" "Verifying SHA-256..." "$VERSION" ""
    verify_checksum "$STAGED_TARBALL" "$CHECKSUM_URL" ""
    if [ $? -eq 2 ]; then
        rm -f "$STAGED_TARBALL"
        die "SHA-256 mismatch — download may be corrupt or tampered"
    fi

    # 4. Stage version marker
    echo "$VERSION" > "$STAGED_VERSION"

    # 5. Report ready
    local_size=$(du -k "$STAGED_TARBALL" 2>/dev/null | awk '{printf "%.1f MB", $1/1024}')
    write_status "ready" "Download verified ($local_size)" "$VERSION" "$local_size"
    log "Staged $VERSION ($local_size) — ready for install"

    rm -f "$PID_FILE"
    trap - EXIT INT TERM
    exit 0
fi

# =============================================================================
# INSTALL_STAGED mode — install a previously downloaded tarball
# =============================================================================
if [ "$MODE" = "install_staged" ]; then
    STAGED_TARBALL="/tmp/qmanager_staged.tar.gz"
    STAGED_VERSION="/tmp/qmanager_staged_version"

    [ -f "$STAGED_TARBALL" ] || die "No staged tarball found. Download first."
    [ -f "$STAGED_VERSION" ] || die "No staged version marker found."

    VERSION=$(cat "$STAGED_VERSION" 2>/dev/null)
    log "Installing staged version: $VERSION"

    # 1. Save current version for rollback tracking
    write_status "installing" "Installing QManager ${VERSION}..." "$VERSION" ""
    current_ver=$(get_current_version)
    mkdir -p "$UPDATES_DIR"
    echo "$current_ver" > "$UPDATES_DIR/previous_version"
    log "Saved previous version ($current_ver)"

    # 2. Extract and run installer with step-streaming progress
    rm -rf /tmp/qmanager_install
    tar xzf "$STAGED_TARBALL" -C /tmp/
    rm -f "$STAGED_TARBALL" "$STAGED_VERSION"
    cd /tmp/qmanager_install || die "Extraction failed — /tmp/qmanager_install not found"

    log "Running install_rm520n.sh --force --skip-packages --no-reboot"
    if ! run_install_with_progress "$VERSION"; then
        die "Installation failed. Check $LOG_FILE for details."
    fi
    log "Install complete"

    # 3. Verify the VERSION file was stamped correctly
    post_install_check "$VERSION"

    # 4. Cleanup and reboot
    rm -rf /tmp/qmanager_install
    write_status "rebooting" "Rebooting device..." "$VERSION" ""
    log "Rebooting"
    rm -f "$PID_FILE"
    trap - EXIT INT TERM
    wait_for_reboot_ack
    reboot
    exit 0
fi

# =============================================================================
# ROLLBACK mode
# =============================================================================
if [ "$MODE" = "rollback" ]; then
    URL="$2"
    VERSION="$3"

    if [ -z "$URL" ] || [ -z "$VERSION" ]; then
        die "Rollback requires URL and version arguments"
    fi

    # Strict validation — rollback only downloads from official releases
    if ! validate_url "$URL" "strict"; then
        die "Invalid rollback URL"
    fi

    # 1. Download rollback archive
    write_status "downloading" "Downloading previous version..." "$VERSION" ""
    log "Downloading rollback archive $URL"
    download_path="/tmp/qmanager_rollback.tar.gz"
    rm -f "$download_path"

    if ! http_download "$URL" "$download_path"; then
        die "Rollback download failed. Check your internet connection."
    fi
    log "Rollback download complete"

    # 2. Verify archive integrity
    if ! verify_archive "$download_path"; then
        rm -f "$download_path"
        die "Rollback archive is corrupt or missing install_rm520n.sh."
    fi
    log "Rollback archive verified"

    # 3. Save current version so the next rollback can swap back
    write_status "installing" "Restoring previous version..." "$VERSION" ""
    current_ver=$(get_current_version)
    mkdir -p "$UPDATES_DIR"
    echo "$current_ver" > "$UPDATES_DIR/previous_version"
    log "Saved current version ($current_ver) before rollback"

    # 4. Extract and run installer with step-streaming progress
    rm -rf /tmp/qmanager_install
    tar xzf "$download_path" -C /tmp/
    rm -f "$download_path"
    cd /tmp/qmanager_install || die "Extraction failed"

    log "Running install_rm520n.sh --force --skip-packages --no-reboot"
    if ! run_install_with_progress "$VERSION"; then
        die "Rollback installation failed. Check $LOG_FILE"
    fi
    log "Rollback install complete"

    # 5. Verify the VERSION file was stamped correctly
    post_install_check "$VERSION"

    # 6. Cleanup and reboot
    rm -rf /tmp/qmanager_install
    write_status "rebooting" "Rebooting device..." "$VERSION" ""
    log "Rebooting"
    rm -f "$PID_FILE"
    trap - EXIT INT TERM
    wait_for_reboot_ack
    reboot
    exit 0
fi

die "Unknown mode: $MODE"
