#!/bin/sh
# =============================================================================
# qcmd_test — Smoke test for qcmd on RM520N-GL
# =============================================================================
# Validates the full chain: atcli_smd11 → /dev/smd11 → modem
#
# Run this after installing atcli_smd11 and qcmd on the device:
#   1. Ensure atcli_smd11 is installed at /usr/bin/atcli_smd11
#   2. Ensure qcmd is installed at /usr/bin/qcmd
#   3. Ensure /dev/smd11 is not locked by socat-at-bridge
#   4. Run: sh /usr/bin/qcmd_test
#
# Install location: /usr/bin/qcmd_test
# =============================================================================

PASS=0
FAIL=0
WARN=0

pass() { PASS=$((PASS + 1)); echo "  PASS"; }
fail() { FAIL=$((FAIL + 1)); echo "  FAIL: $1"; }
warn() { WARN=$((WARN + 1)); echo "  WARN: $1"; }

echo "=== qcmd RM520N-GL Smoke Test ==="
echo ""

# --- Test 1: atcli_smd11 binary exists ---------------------------------------
echo "[1] atcli_smd11 binary..."
if [ -x /usr/bin/atcli_smd11 ]; then
    pass
else
    fail "atcli_smd11 not found or not executable at /usr/bin/atcli_smd11"
    echo "=== Aborting (atcli_smd11 required for all tests) ==="
    exit 1
fi

# --- Test 2: AT device exists ------------------------------------------------
echo "[2] AT device /dev/smd11..."
if [ -e /dev/smd11 ]; then
    pass
else
    fail "/dev/smd11 not found"
    echo "=== Aborting (AT device required) ==="
    exit 1
fi

# --- Test 3: Direct atcli_smd11 AT command -----------------------------------
echo "[3] Direct atcli_smd11: ATI..."
r=$(/usr/bin/atcli_smd11 "ATI" 2>/dev/null)
if [ -n "$r" ] && echo "$r" | grep -q "Quectel\|RM520\|OK"; then
    pass
elif [ -z "$r" ]; then
    fail "empty response — modem may not be responding"
else
    warn "got response but unexpected content: $(echo "$r" | head -1)"
fi

# --- Test 4: qcmd simple command --------------------------------------------
echo "[4] qcmd: AT..."
r=$(qcmd "AT" 2>/dev/null)
rc=$?
if [ $rc -eq 0 ] && echo "$r" | grep -q "OK"; then
    pass
elif [ $rc -ne 0 ]; then
    fail "qcmd exit code $rc"
else
    warn "qcmd returned 0 but unexpected content"
fi

# --- Test 5: Compound AT command ---------------------------------------------
echo "[5] Compound: AT+CGMM;+CGSN..."
r=$(qcmd 'AT+CGMM;+CGSN' 2>/dev/null)
rc=$?
if [ $rc -eq 0 ] && [ -n "$r" ]; then
    if echo "$r" | grep -qE 'RM520|RM5|[0-9]{15}'; then
        pass
    else
        warn "response received but could not identify model/IMEI"
        echo "    Response: $(echo "$r" | head -3)"
    fi
else
    fail "compound command failed (rc=$rc)"
fi

# --- Test 6: JSON mode ------------------------------------------------------
echo "[6] JSON mode: AT+CSQ..."
r=$(qcmd -j "AT+CSQ" 2>/dev/null)
if echo "$r" | grep -q '"success"'; then
    if echo "$r" | grep -q 'true'; then
        pass
    else
        warn "JSON returned but success!=true"
        echo "    Response: $r"
    fi
else
    fail "invalid JSON response"
fi

# --- Test 7: flock serialization ---------------------------------------------
echo "[7] Concurrent lock test..."
qcmd "AT" >/dev/null 2>&1 &
pid1=$!
qcmd "AT" >/dev/null 2>&1 &
pid2=$!
wait $pid1
rc1=$?
wait $pid2
rc2=$?
if [ $rc1 -eq 0 ] && [ $rc2 -eq 0 ]; then
    pass
else
    warn "one or both calls failed (rc1=$rc1, rc2=$rc2) — may indicate lock contention"
fi

# --- Test 8: Error response handling -----------------------------------------
echo "[8] Error handling: AT+INVALIDCMD..."
r=$(qcmd "AT+INVALIDCMD_XYZ_TEST" 2>&1)
rc=$?
if [ $rc -ne 0 ]; then
    pass
else
    warn "qcmd returned 0 for invalid command — check error detection"
fi

# --- Test 9: SMS via AT commands ---------------------------------------------
echo "[9] SMS storage query (AT+CPMS?)..."
r=$(qcmd "AT+CPMS?" 2>/dev/null)
rc=$?
if [ $rc -eq 0 ] && echo "$r" | grep -q "+CPMS:"; then
    pass
else
    warn "SMS storage query failed (rc=$rc)"
fi

# --- Test 10: Device availability -------------------------------------------
echo "[10] /dev/smd11 not locked by socat..."
if fuser /dev/smd11 2>/dev/null | grep -q .; then
    # Something is using smd11 — check if it's socat
    if ps aux 2>/dev/null | grep -q "socat.*smd11"; then
        warn "/dev/smd11 may be locked by socat-at-bridge — stop socat-smd11 services"
    else
        pass
    fi
else
    pass
fi

# --- Summary -----------------------------------------------------------------
echo ""
echo "=== Results ==="
echo "  Passed: $PASS"
echo "  Failed: $FAIL"
echo "  Warnings: $WARN"
echo ""

if [ $FAIL -eq 0 ]; then
    echo "All critical tests passed. qcmd is ready for RM520N-GL."
    exit 0
else
    echo "Some tests failed. Review output above before proceeding."
    exit 1
fi
