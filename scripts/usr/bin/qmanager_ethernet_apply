#!/bin/sh
# Apply ethernet link-speed limit on eth0. Persist to /etc/qmanager/ethernet_speed.
# Called by CGI via: sudo -n /usr/bin/qmanager_ethernet_apply <auto|10|100|1000|2500>
#
# Usage:
#   qmanager_ethernet_apply auto     — advertise all supported modes, autoneg on
#   qmanager_ethernet_apply 10       — cap at 10 Mb/s (autoneg with 10baseT mask)
#   qmanager_ethernet_apply 100      — cap at 100 Mb/s
#   qmanager_ethernet_apply 1000     — cap at 1 Gb/s
#   qmanager_ethernet_apply 2500     — cap at 2.5 Gb/s

ETH_INTERFACE="eth0"
ETHTOOL="/usr/sbin/ethtool"
ETHERNET_SPEED_FILE="/etc/qmanager/ethernet_speed"
CONF_DIR="/etc/qmanager"

. /usr/lib/qmanager/ethtool_helper.sh

# --- Input validation ---------------------------------------------------------
speed_limit="$1"

case "$speed_limit" in
    auto|10|100|1000|2500) ;;
    *)
        printf '{"success":false,"error":"invalid_input","detail":"speed_limit must be one of: auto, 10, 100, 1000, 2500"}\n'
        exit 1
        ;;
esac

# --- No-NIC branch -------------------------------------------------------------
# Many boxes have no RTL8125B 2.5GbE dongle attached, so eth0 never shows up
# under /sys/class/net. This is called both from qmanager-ethernet.service at
# boot and directly from the CGI apply path — neither caller should see a hard
# failure just because the hardware isn't present. Persist the requested
# preference (so it takes effect automatically if the dongle is hot-plugged or
# present on a later boot) and exit clean.
if [ ! -e "/sys/class/net/$ETH_INTERFACE" ]; then
    echo "qmanager_ethernet_apply: $ETH_INTERFACE not present (no RTL8125B NIC attached) — skipping ethtool, preference persisted" >&2

    mkdir -p "$CONF_DIR"
    printf '%s\n' "$speed_limit" > "${ETHERNET_SPEED_FILE}.tmp"
    mv "${ETHERNET_SPEED_FILE}.tmp" "$ETHERNET_SPEED_FILE"

    printf '{"success":true,"speed_limit":"%s","applied":false,"reason":"no_nic"}\n' "$speed_limit"
    exit 0
fi

# --- Build ethtool advertise mask and apply ----------------------------------

case "$speed_limit" in
    auto)
        # Advertise everything the PHY supports
        adv_hex=$(get_supported_advertise_hex)
        if [ -n "$adv_hex" ]; then
            "$ETHTOOL" -s "$ETH_INTERFACE" advertise "$adv_hex" autoneg on 2>/dev/null
        else
            # Fallback: just turn autoneg on without restricting advertise mask
            "$ETHTOOL" -s "$ETH_INTERFACE" autoneg on 2>/dev/null
        fi
        ;;
    10)
        # 10baseT/Half (bit 0) + 10baseT/Full (bit 1) = 0x003
        "$ETHTOOL" -s "$ETH_INTERFACE" advertise 0x003 autoneg on 2>/dev/null
        ;;
    100)
        # 10baseT/Half+Full (0x003) + 100baseT/Half (bit 2) + 100baseT/Full (bit 3) = 0x00f
        "$ETHTOOL" -s "$ETH_INTERFACE" advertise 0x00f autoneg on 2>/dev/null
        ;;
    1000)
        # 10/100 mask (0x00f) + 1000baseT/Half (bit 4) + 1000baseT/Full (bit 5) = 0x02f
        "$ETHTOOL" -s "$ETH_INTERFACE" advertise 0x02f autoneg on 2>/dev/null
        ;;
    2500)
        # 2500baseT/Full = bit 47; expressed as hi=0x8000 lo=0x00000000 → 0x800000000000
        "$ETHTOOL" -s "$ETH_INTERFACE" advertise 0x800000000000 autoneg on 2>/dev/null
        ;;
esac

ethtool_rc=$?

if [ "$ethtool_rc" -ne 0 ]; then
    printf '{"success":false,"error":"ethtool_failed","detail":"ethtool -s exited %d"}\n' "$ethtool_rc"
    exit 1
fi

# --- Force PHY renegotiation -------------------------------------------------
"$ETHTOOL" -r "$ETH_INTERFACE" 2>/dev/null || true

# --- Persist atomically ------------------------------------------------------
mkdir -p "$CONF_DIR"
printf '%s\n' "$speed_limit" > "${ETHERNET_SPEED_FILE}.tmp"
mv "${ETHERNET_SPEED_FILE}.tmp" "$ETHERNET_SPEED_FILE"

printf '{"success":true,"speed_limit":"%s"}\n' "$speed_limit"
exit 0
