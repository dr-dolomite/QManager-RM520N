#!/bin/sh
# =============================================================================
# qmanager_auto_update — Unattended update check + install
# =============================================================================
# Triggered by the qmanager-auto-update.timer systemd unit (OnCalendar, daily-
# ish, with a randomized delay so a fleet doesn't stampede GitHub at once).
# Checks GitHub Releases API for a newer version and, if found, hands off to
# qmanager_update (install mode, --unattended) to download, verify, install,
# and reboot.
#
# Config (config.sh, section "update" — the same keys the System Settings ->
# Software Update UI already writes via update.sh action=save_auto_update):
#   auto_update_enabled  1/0  master on/off switch, checked at runtime below
#   include_prerelease   1/0  whether pre-release GitHub tags are eligible
#
# NOTE: this same "update.auto_update_enabled" flag is ALSO consulted by the
# legacy update.sh crontab-writer (root's /var/spool/cron/crontabs/root) —
# that mechanism predates this timer and is dead in practice on RM520N-GL
# (no crond/cronie/busybox-cron runs on-device; see docs/reference/timezone.md
# for the on-device verification). The systemd timer is the real trigger now;
# this runtime check is belt-and-suspenders so an accidentally-enabled timer
# still does nothing unless the user has actually opted in via the UI.
#
# Lock: /tmp/qmanager_update.pid (shared with manual updates)
# =============================================================================

. /usr/lib/qmanager/qlog.sh 2>/dev/null || {
    qlog_init() { :; }
    qlog_info() { logger -t auto_update "$1"; }
    qlog_warn() { logger -t auto_update "WARN: $1"; }
}

[ -f /usr/lib/qmanager/config.sh ] && . /usr/lib/qmanager/config.sh
[ -f /usr/lib/qmanager/semver.sh ] && . /usr/lib/qmanager/semver.sh

# Downloader abstraction (curl/wget auto-detect). Inline fallback in case the
# library is absent — cron runs with a sparse PATH, so resolve /opt/bin too.
if [ -f /usr/lib/qmanager/downloader.sh ]; then
    . /usr/lib/qmanager/downloader.sh
else
    export PATH="/opt/bin:/opt/sbin:/usr/bin:/usr/sbin:/bin:/sbin:$PATH"
    qm_download() {
        local rc
        if command -v curl >/dev/null 2>&1; then
            curl -fSL --max-time "${3:-120}" -o "$2" "$1"
        elif command -v wget >/dev/null 2>&1; then
            wget -q -T "${3:-120}" -O "$2" "$1"
        else
            return 1
        fi
        rc=$?
        [ "$rc" -ne 0 ] && rm -f "$2"
        return "$rc"
    }
fi

qlog_init "auto_update"

# --- Configuration -----------------------------------------------------------

REPO="dr-dolomite/QManager-RM520N"
VERSION_FILE="/etc/qmanager/VERSION"
PID_FILE="/tmp/qmanager_update.pid"
UPDATER="/usr/bin/qmanager_update"

# --- Guard: master on/off switch ---------------------------------------------
# Belt-and-suspenders: qmanager-auto-update.timer is installed system-wide but
# gated by the installer (only wanted/started if the user had already opted
# in). This check makes a stray "timer enabled but feature off" state a clean
# no-op too, rather than relying solely on systemd enablement. Default is "0"
# (off) — matches config.sh's seeded default, so a device that has never
# touched the Software Update settings page never auto-updates.
if command -v qm_config_get >/dev/null 2>&1; then
    auto_update_enabled=$(qm_config_get update auto_update_enabled 0)
    if [ "$auto_update_enabled" != "1" ]; then
        qlog_info "Auto-update disabled (update.auto_update_enabled != 1) — exiting"
        exit 0
    fi
else
    qlog_warn "config.sh not available — cannot confirm auto-update is enabled, exiting"
    exit 0
fi

# --- Guard: skip if update already in progress -------------------------------

if [ -f "$PID_FILE" ]; then
    pid=$(cat "$PID_FILE" 2>/dev/null)
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
        qlog_info "Update already in progress (PID $pid), skipping"
        exit 0
    fi
    rm -f "$PID_FILE"
fi

# --- Read current state ------------------------------------------------------

current_version=$(tr -d '[:space:]' < "$VERSION_FILE" 2>/dev/null)
[ -z "$current_version" ] && current_version="0.0.0"

include_prerelease=$(qm_config_get update include_prerelease 1)

# --- Fetch GitHub releases ---------------------------------------------------

api_url="https://api.github.com/repos/$REPO/releases"
tmp_body="/tmp/qm_auto_update_body.json"
rm -f "$tmp_body"

fetched=0
if qm_download "$api_url" "$tmp_body" 15 2>/dev/null && [ -s "$tmp_body" ]; then
    fetched=1
fi

if [ "$fetched" != "1" ]; then
    qlog_warn "Failed to fetch releases from GitHub (no curl/wget, or network down)"
    rm -f "$tmp_body"
    exit 1
fi

# --- Parse latest version ----------------------------------------------------

if [ "$include_prerelease" = "1" ]; then
    filter='.[0]'
else
    filter='[ .[] | select(.prerelease == false) ] | .[0]'
fi

latest_tag=$(jq -r "$filter | .tag_name // empty" "$tmp_body")
rm -f "$tmp_body"

if [ -z "$latest_tag" ]; then
    qlog_info "No releases found"
    exit 0
fi

# --- Check + install ---------------------------------------------------------

semver_compare "$latest_tag" "$current_version"
case $? in
    0) ;; # latest is newer — continue to install
    *) qlog_info "Up to date ($current_version)"; exit 0 ;;
esac

download_url="https://github.com/${REPO}/releases/download/${latest_tag}/qmanager.tar.gz"
qlog_info "Auto-update: installing $latest_tag (current: $current_version)"
# --unattended makes qmanager_update treat a missing/unverifiable SHA-256 as
# fatal instead of best-effort — nobody is watching this progress UI to catch
# a bad install before it reboots the device. (4th arg is download_size,
# which auto-update never knows ahead of time — left empty like before.)
exec "$UPDATER" install "$download_url" "$latest_tag" "" --unattended
