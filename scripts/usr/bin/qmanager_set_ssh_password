#!/bin/sh
# =============================================================================
# qmanager_set_ssh_password — Set root password for SSH access
# =============================================================================
# Reads the new password from stdin (one line). Updates /etc/shadow with an
# MD5-crypt hash. Password never appears in command-line args (invisible to ps).
#
# Called via sudo by CGI scripts (www-data). Must be whitelisted in sudoers.
#
# Usage:  printf '%s\n' "$password" | sudo /usr/bin/qmanager_set_ssh_password
# Exit:   0 = success, 1 = failure (JSON error on stdout)
#
# Install location: /usr/bin/qmanager_set_ssh_password
# =============================================================================

# Read password from stdin (single line, no echo)
read -r _password

if [ -z "$_password" ]; then
    printf '{"success":false,"error":"empty_password","detail":"Password is required"}\n'
    exit 1
fi

# Validate minimum length
_pw_len=$(printf '%s' "$_password" | wc -c)
if [ "$_pw_len" -lt 6 ]; then
    printf '{"success":false,"error":"password_too_short","detail":"Password must be at least 6 characters"}\n'
    exit 1
fi

# Generate 8-char hex salt from /dev/urandom
_salt=$(head -c 4 /dev/urandom | od -A n -t x1 | tr -d ' \n')

# Generate MD5-crypt hash ($1$salt$hash) — universally supported on BusyBox
_hash=$(printf '%s\n' "$_password" | openssl passwd -1 -salt "$_salt" -stdin 2>/dev/null)

if [ -z "$_hash" ]; then
    printf '{"success":false,"error":"hash_failed","detail":"Failed to generate password hash"}\n'
    exit 1
fi

# Remount root filesystem read-write if needed
if ! touch /usr/.qm_rw_test 2>/dev/null; then
    mount -o remount,rw / 2>/dev/null || {
        printf '{"success":false,"error":"remount_failed","detail":"Could not remount / read-write"}\n'
        exit 1
    }
fi
rm -f /usr/.qm_rw_test

# Update root's password field in /etc/shadow
# Format: root:$hash:days_since_epoch:min:max:warn:inactive:expire:reserved
if [ ! -f /etc/shadow ]; then
    printf '{"success":false,"error":"no_shadow","detail":"/etc/shadow not found"}\n'
    exit 1
fi

# Escape special characters in hash for sed ($ and / are common in crypt hashes)
_escaped_hash=$(printf '%s' "$_hash" | sed 's/[&/\]/\\&/g')

sed -i "s|^root:[^:]*:|root:${_escaped_hash}:|" /etc/shadow 2>/dev/null

if [ $? -ne 0 ]; then
    printf '{"success":false,"error":"shadow_update_failed","detail":"Failed to update /etc/shadow"}\n'
    exit 1
fi

printf '{"success":true}\n'
exit 0
